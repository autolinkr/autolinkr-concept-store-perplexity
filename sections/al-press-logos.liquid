{% comment %}
  AutoLinkr — As Featured In / Press Logos
  White logo bar on dark background. CDN URLs wired directly — no image_picker needed.
{% endcomment %}

<section class="al-press" style="
  background: rgb(var(--color-base-background));
  padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  border-top: 1px solid rgba(59,142,248,0.1);
  border-bottom: 1px solid rgba(59,142,248,0.1);
">
  <div class="page-width" style="max-width:1200px;margin:0 auto;padding:0 24px;">

    {%- if section.settings.eyebrow != blank -%}
      <p class="al-press__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}

    <div class="al-press__logos">
      {%- for block in section.blocks -%}
        {%- if block.type == 'logo' and block.settings.image_url != blank -%}
          <div class="al-press__item" {{ block.shopify_attributes }}>
            {%- if block.settings.link != blank -%}
              <a href="{{ block.settings.link }}" target="_blank" rel="noopener noreferrer" class="al-press__link">
            {%- endif -%}
              <img
                src="{{ block.settings.image_url }}"
                alt="{{ block.settings.name | default: 'Press logo' | escape }}"
                loading="lazy"
                style="height:{{ block.settings.height | default: 28 }}px;width:auto;display:block;"
              >
            {%- if block.settings.link != blank -%}
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

<style>
  .al-press__eyebrow {
    text-align: center;
    font-family: var(--al-font-body, 'Inter', sans-serif);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--al-text-4, rgba(255,255,255,0.35));
    margin: 0 0 28px;
  }

  .al-press__logos {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 40px 56px;
  }

  .al-press__item {
    opacity: 0.55;
    transition: opacity 0.2s ease;
    display: flex;
    align-items: center;
  }

  .al-press__item:hover { opacity: 1; }

  .al-press__link { display: block; }

  .al-press__item img {
    filter: brightness(0) invert(1);
    max-width: 140px;
  }

  @media (max-width: 768px) {
    .al-press__logos { gap: 28px 36px; }
    .al-press__item img { max-width: 100px; }
  }
</style>

{% schema %}
{
  "name": "AL — Press Logos",
  "tag": "section",
  "settings": [
    { "type": "range", "id": "padding_top",    "label": "Padding top",    "min": 20, "max": 100, "step": 4, "default": 40, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 20, "max": 100, "step": 4, "default": 40, "unit": "px" },
    { "type": "text",  "id": "eyebrow", "label": "Eyebrow label", "default": "As Featured In" }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        { "type": "text",  "id": "name",      "label": "Publication name" },
        { "type": "text",  "id": "image_url", "label": "Logo CDN URL", "info": "Paste Shopify CDN URL of the white PNG logo" },
        { "type": "range", "id": "height",    "label": "Logo height (px)", "min": 16, "max": 64, "step": 2, "default": 28 },
        { "type": "url",   "id": "link",      "label": "Link (optional)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "AL — Press Logos",
      "settings": { "eyebrow": "As Featured In" }
    }
  ]
}
{% endschema %}
