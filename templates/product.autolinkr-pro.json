    "faq": {
      "type": "faq",
      "blocks": {
        "q1": {
          "type": "question",
          "settings": {
            "title": "Will this work with my car?",
            "text": "<p>Works with any 2016+ vehicle with factory CarPlay or Android Auto \u2014 that's 500+ models from Toyota, Honda, Ford, BMW, and 30+ brands. Not compatible with Tesla, Rivian, or Lucid.</p><p><a href=\"/pages/supported-cars\">Check your car \u2192</a></p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "q2": {
          "type": "question",
          "settings": {
            "title": "Does it work with both iPhone and Android?",
            "text": "<p>Yes. AutoLinkr Pro\u2122 supports both wireless Apple CarPlay and wireless Android Auto. It detects your phone automatically on first connection.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "q3": {
          "type": "question",
          "settings": {
            "title": "Do I need WiFi for streaming?",
            "text": "<p>Streaming uses your phone's mobile hotspot \u2014 just turn it on and AutoLinkr connects automatically. Most plans include hotspot data. Many apps also support offline downloads for when you're out of range.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "q4": {
          "type": "question",
          "settings": {
            "title": "Can I watch Netflix while the car is moving?",
            "text": "<p>Streaming apps remain active while driving \u2014 designed for passenger use. AutoLinkr does not restrict playback, but the driver should never watch video while operating the vehicle.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "q5": {
          "type": "question",
          "settings": {
            "title": "What if it doesn't work with my car?",
            "text": "<p>30-day money-back guarantee. Return it for full in-store credit. We cover return shipping. No questions asked.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "q6": {
          "type": "question",
          "settings": {
            "title": "Can I move it between cars?",
            "text": "<p>Absolutely. It's completely portable \u2014 unplug from one car's USB port and plug into another. Works instantly in any compatible vehicle.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "q7": {
          "type": "question",
          "settings": {
            "title": "How long does shipping take?",
            "text": "<p>Free standard shipping on all orders, 6-10 business days. Most orders placed before 2pm ET ship the same day.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "q8": {
          "type": "question",
          "settings": {
            "title": "What's the difference between Pro and Elite?",
            "text": "<p>Both include wireless CarPlay/Android Auto and full streaming. Elite adds 4x the RAM (8GB), 4x the storage (64GB), split-screen multitasking, and an enhanced UI. For most drivers, the Pro is perfect.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        }
      },
