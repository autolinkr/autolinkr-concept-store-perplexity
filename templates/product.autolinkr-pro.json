    "multicolumn-features": {
      "type": "multicolumn-with-icons",
      "blocks": {
        "col-1": {
          "type": "column",
          "settings": {
            "icon": "bolt",
            "heading": "Instant Wireless Freedom",
            "text": "<p>Pair your iPhone once — every drive connects automatically. No more plugging in, no cables across your lap.</p>"
          }
        },
        "col-2": {
          "type": "column",
          "settings": {
            "icon": "play-button",
            "heading": "Netflix & YouTube On Screen",
            "text": "<p>Stream full HD video on your factory display. Google Play Store unlocks every app your phone can run.</p>"
          }
        },
        "col-3": {
          "type": "column",
          "settings": {
            "icon": "wifi",
            "heading": "5GHz Speed, Zero Lag",
            "text": "<p>Dual-band 5GHz Wi-Fi keeps navigation, music, and calls running smooth — even on long highway drives.</p>"
          }
        },
        "col-4": {
          "type": "column",
          "settings": {
            "icon": "shield",
            "heading": "Plug-In Simple Setup",
            "text": "<p>No app required. No wiring. Connects directly to your factory USB port in under 60 seconds.</p>"
          }
        }
      },
      "block_order": [
        "col-1",
        "col-2",
        "col-3",
        "col-4"
      ],
      "settings": {
        "style": "icons-top",
        "columns": 4,
        "text_alignment": "center",
        "heading": "Why 50,000+ Drivers Choose AutoLinkr Pro™",
        "heading_size": "h3",
