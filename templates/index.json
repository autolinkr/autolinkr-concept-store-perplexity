    "multicolumn-why": {
      "type": "multicolumn-with-icons",
      "blocks": {
        "col-1": {
          "type": "column",
          "settings": {
            "icon": "wifi",
            "heading": "Truly Wireless CarPlay",
            "text": "<p>Cut the cord permanently. AutoLinkr converts your factory wired CarPlay to wireless \u2014 pair once and every future drive auto-connects in seconds. No cables, ever again.</p>"
          }
        },
        "col-2": {
          "type": "column",
          "settings": {
            "icon": "play-button",
            "heading": "Netflix, YouTube & More",
            "text": "<p>Stream full HD on your car's own display. The Google Play Store unlocks every app your phone already runs \u2014 no sideloading, no hacks.</p>"
          }
        },
        "col-3": {
          "type": "column",
          "settings": {
            "icon": "bolt",
            "heading": "Works With Your Car",
            "text": "<p>Compatible with 97%+ of vehicles with factory wired CarPlay. BMW, Mercedes, Toyota, Ford, Honda, and 100+ other makes. No modifications needed.</p>"
          }
        },
        "col-4": {
          "type": "column",
          "settings": {
            "icon": "truck",
            "heading": "Free Shipping on All Orders",
            "text": "<p>Every AutoLinkr order ships free, no minimums. Most US customers receive delivery within 3\u20135 business days after a 1\u20132 day processing window.</p>"
          }
        }
      },
