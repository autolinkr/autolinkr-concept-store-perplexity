          "type": "collapsible_tab",
          "settings": {
            "opened": true,
            "style": "with-border",
            "icon": "none",
            "heading": "What's Included",
            "content": "<ul><li>AutoLinkr Elite™ Adapter</li><li>USB-A to USB-C Cable (high-speed)</li><li>Premium Quick-Start Guide</li></ul>",
            "text_size": "text-sm"
          }
        },
        "collapsible-works-with": {
          "type": "collapsible_tab",
          "settings": {
            "opened": false,
            "style": "with-border",
            "icon": "none",
            "heading": "Works With",
            "content": "<p><strong>Requirements:</strong> Vehicle must have factory-installed wired CarPlay. AutoLinkr Elite™ does NOT add CarPlay to vehicles without it.</p><p><strong>Compatible iPhones:</strong> iPhone 7 and newer running iOS 10+</p><p><strong>Compatible Vehicles:</strong> Any car with factory wired CarPlay (2016+). Works with BMW, Mercedes, Honda, Toyota, Ford, Chevy, Audi, VW, and 100+ other makes.</p>",
            "text_size": "text-sm"
          }
        },
        "collapsible-streaming": {
          "type": "collapsible_tab",
          "settings": {
            "opened": false,
            "style": "with-border",
            "icon": "none",
            "heading": "Streaming + Split-Screen Apps",
            "content": "<p>AutoLinkr Elite™ unlocks the full streaming ecosystem AND split-screen multitasking:</p><ul><li>Netflix + navigation simultaneously (split-screen)</li><li>YouTube</li><li>Google Play Store (download any app)</li><li>Hulu, Disney+, Amazon Prime Video</li><li>Spotify, Apple Music</li><li>Waze + YouTube Music side-by-side</li></ul><p><em>Split-screen lets you run two apps at once on your factory display — exclusive to Elite.</em></p>",
            "text_size": "text-sm"
          }
        },
        "collapsible-elite-vs-pro": {
          "type": "collapsible_tab",
          "settings": {
            "opened": false,
            "style": "with-border",
            "icon": "none",
            "heading": "Elite vs. Pro — What's the Difference?",
            "content": "<p><strong>AutoLinkr Pro™</strong> — Wireless CarPlay + full streaming (Netflix, YouTube, Google Play). Single app at a time.</p><p><strong>AutoLinkr Elite™</strong> — Everything in Pro, PLUS split-screen multitasking (run 2 apps side-by-side) and a faster processor for zero-lag performance.</p><p>If you're a power user who wants the absolute best — Elite is your choice.</p>",
            "text_size": "text-sm"
          }
        },
