      "blocks": {
        "f1": {"type": "item", "settings": {"icon": "bolt", "title": "60-Second Setup", "subtitle": "Plug in and go"}},
        "f2": {"type": "item", "settings": {"icon": "truck", "title": "Free Shipping", "subtitle": "On every order"}},
        "f3": {"type": "item", "settings": {"icon": "shield", "title": "30-Day Guarantee", "subtitle": "Full refund, no hassle"}},
