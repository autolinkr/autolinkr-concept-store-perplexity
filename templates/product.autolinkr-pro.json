    "how-it-works": {
      "type": "multicolumn-with-icons",
      "blocks": {
        "step1": {
          "type": "column",
          "settings": {
            "icon": "plug",
            "heading": "1 — Plug In",
            "text": "<p>Connect AutoLinkr Pro™ to your car's factory CarPlay USB port using the included cable.</p>"
          }
        },
        "step2": {
          "type": "column",
          "settings": {
            "icon": "bluetooth",
            "heading": "2 — Pair Once",
            "text": "<p>Connect your iPhone via Bluetooth to 'HI-BOX:' and connect to the Wi-Fi hotspot. Takes about 60 seconds total.</p>"
          }
        },
        "step3": {
          "type": "column",
          "settings": {
            "icon": "wifi",
            "heading": "3 — Auto-Connect",
            "text": "<p>Every future drive connects automatically when you start the car. No more plugging in — ever.</p>"
          }
        },
        "step4": {
          "type": "column",
          "settings": {
            "icon": "play-button",
            "heading": "4 — Stream & Drive",
            "text": "<p>Open Netflix, YouTube, or any Google Play app directly on your factory screen. Welcome to wireless freedom.</p>"
          }
        }
