    "how-it-works": {
      "type": "al-how-it-works",
      "blocks": {
        "step-1": {
          "type": "step",
          "settings": {
            "heading": "1. Plug In",
            "body": "Connect AutoLinkr Elite\u2122 to your car's factory CarPlay USB port using the included cable. Fits in under 30 seconds.",
            "badge": "Under 30 sec",
            "image_url": "https://cdn.shopify.com/s/files/1/0706/8971/8306/files/Elite_Plugged.png?v=1772338923",
            "image_ratio": "4/3"
          }
        },
        "step-2": {
          "type": "step",
          "settings": {
            "heading": "2. Connect",
            "body": "Pair your iPhone via Bluetooth and join the AutoLinkr Wi-Fi hotspot. One-time setup \u2014 your car remembers everything after that.",
            "badge": "One-time only",
            "image_url": "https://cdn.shopify.com/s/files/1/0706/8971/8306/files/2M2A9259.jpg?v=1773548940",
            "image_ratio": "16/9"
          }
        },
        "step-3": {
          "type": "step",
          "settings": {
            "heading": "3. Enjoy",
            "body": "Wireless CarPlay launches automatically every time you start your car. No cables, no steps \u2014 just wireless freedom on every drive.",
            "badge": "Automatic every drive",
            "image_url": "https://cdn.shopify.com/s/files/1/0706/8971/8306/files/TacomaUI_3.png?v=1773554015",
            "image_ratio": "16/9"
          }
        },
        "step-4": {
          "type": "step",
          "settings": {
            "heading": "4. Go Elite \u2014 Split & Stream",
            "body": "Enable split-screen mode and run navigation side-by-side with Netflix, YouTube, or any streaming app. Welcome to Elite.",
            "badge": "Elite exclusive",
            "image_url": "https://cdn.shopify.com/s/files/1/0706/8971/8306/files/Elite_Main_2_Adnan.png?v=1772338923",
            "image_ratio": "4/3"
          }
        }
      },
