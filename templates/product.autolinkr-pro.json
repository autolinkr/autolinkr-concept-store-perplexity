    "image-netflix": {
      "type": "image-with-text",
      "blocks": {
        "heading": {
          "type": "heading",
          "settings": {
            "heading": "Netflix. YouTube. Google Play. — All on your factory screen.",
            "heading_size": "h2"
          }
        },
        "text": {
          "type": "text",
          "settings": {
            "text": "<p>AutoLinkr Pro™ unlocks the full streaming universe on your car's existing display. The Google Play Store lets you install virtually any Android app — not just what Apple pre-approves for CarPlay.</p><p>Use responsibly: streaming apps are designed for parked use or passenger control.</p>",
            "text_size": "text-base"
          }
        },
        "button": {
          "type": "button",
          "settings": {
            "button_label": "Shop AutoLinkr Pro™ — $79.99",
            "button_link": "/products/the-autolinkr-pro",
            "button_style": "primary"
          }
        }
      },
