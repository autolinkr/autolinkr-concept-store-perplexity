{% comment %}
  AutoLinkr Lifestyle Gallery — v1.0
  Asymmetric masonry-style photo grid with up to 5 CDN images
  Used on Pro/Elite product pages to showcase lifestyle photography
{% endcomment %}

{%- style -%}
.al-lg {
  background: var(--al-bg);
  padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  overflow: hidden;
}

.al-lg__header {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 24px 40px;
  text-align: center;
}

.al-lg__eyebrow {
  display: inline-block;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--al-accent);
  margin-bottom: 12px;
}

.al-lg__heading {
  font-family: 'General Sans', -apple-system, sans-serif;
  font-size: clamp(1.875rem, 3.8vw, 3rem);
  font-weight: 700;
  letter-spacing: -0.03em;
  color: var(--al-text-1);
  margin: 0 0 16px;
  line-height: 1.1;
}

.al-lg__sub {
  font-size: 1.0625rem;
  color: var(--al-text-3);
  max-width: 500px;
  margin: 0 auto;
  line-height: 1.6;
}

/* === GRID LAYOUT === */
.al-lg__grid {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 24px;
  display: grid;
  grid-template-columns: repeat(12, 1fr);
  grid-template-rows: auto;
  gap: 12px;
}

/* Item 1 — large left hero */
.al-lg__item:nth-child(1) {
  grid-column: 1 / 8;
  grid-row: 1 / 3;
}

/* Item 2 — top right */
.al-lg__item:nth-child(2) {
  grid-column: 8 / 13;
  grid-row: 1;
}

/* Item 3 — bottom right */
.al-lg__item:nth-child(3) {
  grid-column: 8 / 13;
  grid-row: 2;
}

/* Item 4 — bottom left */
.al-lg__item:nth-child(4) {
  grid-column: 1 / 7;
  grid-row: 3;
}

/* Item 5 — bottom right */
.al-lg__item:nth-child(5) {
  grid-column: 7 / 13;
  grid-row: 3;
}

.al-lg__item {
  position: relative;
  overflow: hidden;
  border-radius: 12px;
  background: var(--al-surface);
  aspect-ratio: unset;
}

.al-lg__item img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 500ms cubic-bezier(0.2, 0, 0, 1);
  min-height: 220px;
}

.al-lg__item:hover img {
  transform: scale(1.04);
}

/* Subtle dark overlay to unify photos */
.al-lg__item::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, transparent 50%, rgba(8,8,9,0.45) 100%);
  pointer-events: none;
}

/* Caption badge on first image */
.al-lg__item:nth-child(1) .al-lg__caption {
  display: flex;
}

.al-lg__caption {
  display: none;
  position: absolute;
  bottom: 20px;
  left: 20px;
  z-index: 2;
  align-items: center;
  gap: 8px;
  background: rgba(8,8,9,0.75);
  backdrop-filter: blur(12px);
  border: 1px solid rgba(59,142,248,0.25);
  border-radius: 8px;
  padding: 8px 14px;
}

.al-lg__caption-text {
  font-size: 0.8125rem;
  font-weight: 600;
  color: var(--al-text-1);
  letter-spacing: 0.01em;
}

.al-lg__caption-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--al-accent);
  flex-shrink: 0;
  animation: al-lg-pulse 2s infinite;
}

@keyframes al-lg-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.35; }
}

/* CTA below grid */
.al-lg__cta-wrap {
  max-width: 1280px;
  margin: 32px auto 0;
  padding: 0 24px;
  text-align: center;
}

.al-lg__cta {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: 'General Sans', -apple-system, sans-serif;
  font-size: 1rem;
  font-weight: 600;
  text-decoration: none;
  color: #fff;
  background: linear-gradient(135deg, var(--al-accent), var(--al-accent-hover));
  padding: 14px 32px;
  border-radius: 10px;
  box-shadow: 0 4px 24px rgba(45,127,249,0.4);
  transition: all 220ms cubic-bezier(0.2,0,0,1);
}

.al-lg__cta:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 36px rgba(45,127,249,0.55);
  color: #fff;
}

/* Mobile: single column stack */
@media (max-width: 768px) {
  .al-lg__grid {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 0 16px;
  }

  .al-lg__item {
    border-radius: 10px;
  }

  .al-lg__item img {
    min-height: 240px;
    aspect-ratio: 16/9;
  }

  .al-lg__item:nth-child(1) img {
    aspect-ratio: 4/3;
    min-height: 280px;
  }

  .al-lg__header {
    padding: 0 16px 28px;
  }
}
{%- endstyle -%}

<section class="al-lg">
  {%- if section.settings.heading != blank or section.settings.eyebrow != blank -%}
    <div class="al-lg__header">
      {%- if section.settings.eyebrow != blank -%}
        <div class="al-lg__eyebrow">{{ section.settings.eyebrow }}</div>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="al-lg__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="al-lg__sub">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="al-lg__grid">
    {%- assign photo_keys = "photo_1,photo_2,photo_3,photo_4,photo_5" | split: "," -%}
    {%- assign alt_keys = "alt_1,alt_2,alt_3,alt_4,alt_5" | split: "," -%}
    {%- assign caption_keys = "caption_1,caption_2,caption_3,caption_4,caption_5" | split: "," -%}

    {%- for key in photo_keys -%}
      {%- assign photo_url = section.settings[key] -%}
      {%- if photo_url != blank -%}
        {%- assign alt_text = section.settings[alt_keys[forloop.index0]] | default: "AutoLinkr lifestyle" -%}
        {%- assign cap_text = section.settings[caption_keys[forloop.index0]] -%}
        <div class="al-lg__item">
          <img src="{{ photo_url }}" alt="{{ alt_text }}" loading="lazy">
          {%- if cap_text != blank and forloop.index == 1 -%}
            <div class="al-lg__caption">
              <span class="al-lg__caption-dot"></span>
              <span class="al-lg__caption-text">{{ cap_text }}</span>
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>

  {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}
    <div class="al-lg__cta-wrap">
      <a href="{{ section.settings.cta_link }}" class="al-lg__cta">
        {{ section.settings.cta_label }}
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 9h12M10 4l5 5-5 5"/>
        </svg>
      </a>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "AL — Lifestyle Gallery",
  "tag": "section",
  "settings": [
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 20, "max": 120, "step": 4, "default": 20, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 20, "max": 120, "step": 4, "default": 20, "unit": "px" },
    { "type": "header", "content": "Section Header" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Real World" },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "See It In Your Car" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "AutoLinkr in action — wireless CarPlay and streaming on factory screens." },
    { "type": "header", "content": "Photos (use CDN URLs)" },
    { "type": "url", "id": "photo_1", "label": "Photo 1 URL (large left)" },
    { "type": "text", "id": "alt_1", "label": "Photo 1 alt text", "default": "AutoLinkr in car" },
    { "type": "text", "id": "caption_1", "label": "Photo 1 caption badge" },
    { "type": "url", "id": "photo_2", "label": "Photo 2 URL (top right)" },
    { "type": "text", "id": "alt_2", "label": "Photo 2 alt text", "default": "AutoLinkr interface" },
    { "type": "text", "id": "caption_2", "label": "Photo 2 caption" },
    { "type": "url", "id": "photo_3", "label": "Photo 3 URL (mid right)" },
    { "type": "text", "id": "alt_3", "label": "Photo 3 alt text", "default": "AutoLinkr setup" },
    { "type": "text", "id": "caption_3", "label": "Photo 3 caption" },
    { "type": "url", "id": "photo_4", "label": "Photo 4 URL (bottom left)" },
    { "type": "text", "id": "alt_4", "label": "Photo 4 alt text", "default": "AutoLinkr plugged in" },
    { "type": "text", "id": "caption_4", "label": "Photo 4 caption" },
    { "type": "url", "id": "photo_5", "label": "Photo 5 URL (bottom right)" },
    { "type": "text", "id": "alt_5", "label": "Photo 5 alt text", "default": "AutoLinkr device" },
    { "type": "text", "id": "caption_5", "label": "Photo 5 caption" },
    { "type": "header", "content": "CTA" },
    { "type": "text", "id": "cta_label", "label": "Button label" },
    { "type": "url", "id": "cta_link", "label": "Button link" }
  ],
  "presets": [
    {
      "name": "AL — Lifestyle Gallery",
      "settings": {
        "eyebrow": "In The Wild",
        "heading": "See It In Your Car",
        "subheading": "Real customers. Real vehicles. Real results.",
        "photo_1": "https://cdn.shopify.com/s/files/1/0706/8971/8306/files/2M2A9259.jpg?v=1773548940",
        "caption_1": "Netflix · Live on Factory Screen",
        "photo_2": "https://cdn.shopify.com/s/files/1/0706/8971/8306/files/2M2A9230-HDR.jpg?v=1773548942",
        "photo_3": "https://cdn.shopify.com/s/files/1/0706/8971/8306/files/2M2A9288.jpg?v=1773548942",
        "photo_4": "https://cdn.shopify.com/s/files/1/0706/8971/8306/files/2M2A9260.jpg?v=1773548940",
        "photo_5": "https://cdn.shopify.com/s/files/1/0706/8971/8306/files/2M2A9277.jpg?v=1773548942"
      }
    }
  ]
}
{% endschema %}
