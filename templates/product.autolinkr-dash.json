    "testimonials-banner": {
      "type": "testimonials-banner",
      "blocks": {
        "t1": {
          "type": "testimonial",
          "settings": {
            "text": "<p>\"A driver hit me in a parking lot and drove off. My AutoLinkr Dash caught the whole thing — plate number and all. The footage was perfect.\"</p>",
            "author": "Rachel S.",
            "author_info": "2020 Toyota RAV4 — Verified Buyer"
          }
        },
        "t2": {
          "type": "testimonial",
          "settings": {
            "text": "<p>\"Night vision is incredible. Most dash cams are useless at night but this one captures everything with full clarity.\"</p>",
            "author": "Tom A.",
            "author_info": "2021 Ford Mustang — Verified Buyer"
          }
        },
        "t3": {
          "type": "testimonial",
          "settings": {
            "text": "<p>\"Easy 20-minute install. The WiFi app lets me pull footage straight to my phone. Exactly what I was looking for.\"</p>",
