{% comment %}
  AutoLinkr — How It Works (3-step with real images)
  Dark premium alternating layout: text left/img right, then flip
  Step number appears at TOP of the text column — not redundant beside heading
{% endcomment %}

<section class="al-hiw" style="
  background: rgb(var(--color-base-background));
  padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
">
  <div class="page-width" style="max-width:1200px;margin:0 auto;padding:0 24px;">

    {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
      <div class="al-hiw__header" style="text-align:center;margin-bottom:64px;">
        {%- if section.settings.eyebrow != blank -%}
          <span class="al-label">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 style="font-family:var(--al-font-display,'General Sans',sans-serif);font-size:clamp(1.875rem,3.5vw,2.75rem);font-weight:700;color:var(--al-text-1);letter-spacing:-0.025em;line-height:1.1;margin:8px auto 16px;max-width:640px;">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p style="color:var(--al-text-3);font-size:1.0625rem;line-height:1.65;max-width:520px;margin:0 auto;">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="al-hiw__steps">
      {%- for block in section.blocks -%}
        {%- if block.type == 'step' -%}
          {%- assign step_num = forloop.index -%}
          {%- assign is_even = forloop.index | modulo: 2 -%}
          <div class="al-step{% if is_even == 0 %} al-step--reverse{% endif %}" {{ block.shopify_attributes }}>

            <div class="al-step__text">
              <h3 class="al-step__heading">{{ block.settings.heading }}</h3>
              <p class="al-step__body">{{ block.settings.body }}</p>
              {%- if block.settings.badge != blank -%}
                <span class="al-label" style="margin-top:16px;display:inline-block;">{{ block.settings.badge }}</span>
              {%- endif -%}
            </div>

            <div class="al-step__img">
              {%- if block.settings.image_url != blank -%}
                <img
                  src="{{ block.settings.image_url }}"
                  alt="{{ block.settings.heading | escape }}"
                  loading="lazy"
                  style="width:100%;height:100%;display:block;object-fit:cover;min-height:320px;"
                >
              {%- elsif block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | image_url: width: 800 }}"
                  alt="{{ block.settings.heading | escape }}"
                  loading="lazy"
                  style="width:100%;height:100%;display:block;object-fit:cover;min-height:320px;"
                >
              {%- else -%}
                <div style="min-height:320px;background:var(--al-surface);display:flex;align-items:center;justify-content:center;color:#404046;font-size:0.875rem;font-family:var(--al-font-display);">Add image in theme editor</div>
              {%- endif -%}
            </div>

          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}
      <div style="text-align:center;margin-top:56px;">
        <a href="{{ section.settings.cta_link }}" class="button button--primary al-btn-glow" style="font-size:1rem;padding:14px 32px;">
          {{ section.settings.cta_label }} →
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

<style>
  /* ── Desktop ── */
  .al-hiw__steps { display: flex; flex-direction: column; gap: 32px; }

  .al-step {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    align-items: stretch;
    background: var(--al-surface);
    border: 2px solid rgba(59, 142, 248, 0.5);
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 0 0 1px rgba(59, 142, 248, 0.12), 0 0 40px rgba(59, 142, 248, 0.08), 0 24px 64px rgba(0,0,0,0.45);
    transition: border-color 0.25s ease, box-shadow 0.25s ease;
  }

  .al-step:hover {
    border-color: rgba(59, 142, 248, 0.85);
    box-shadow: 0 0 0 1px rgba(59, 142, 248, 0.25), 0 0 48px rgba(59, 142, 248, 0.16), 0 24px 64px rgba(0,0,0,0.5);
  }

  /* Alternating flip — desktop only */
  .al-step--reverse .al-step__text { order: 2; }
  .al-step--reverse .al-step__img  { order: 1; }

  .al-step__text {
    padding: 52px 48px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .al-step__heading {
    font-family: var(--al-font-display, 'General Sans', sans-serif);
    font-size: clamp(1.5rem, 2.2vw, 2rem);
    font-weight: 700;
    color: var(--al-text-1);
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin: 0 0 14px;
  }

  .al-step__body {
    font-family: var(--al-font-body, 'Inter', sans-serif);
    font-size: 1.0625rem;
    line-height: 1.65;
    color: var(--al-text-2);
    margin: 0;
  }

  /* Image pane — fixed height so all cards match */
  .al-step__img {
    overflow: hidden;
    background: var(--al-surface-2);
    border-left: 1px solid rgba(59, 142, 248, 0.25);
    height: 360px;
  }

  .al-step--reverse .al-step__img {
    border-left: none;
    border-right: 1px solid rgba(59, 142, 248, 0.25);
  }

  .al-step__img img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .al-hiw__steps { gap: 20px; }

    .al-step {
      grid-template-columns: 1fr;
      border-radius: 16px;
    }

    /* Image always first on mobile — regardless of alternating */
    .al-step__img  { order: 1 !important; }
    .al-step__text { order: 2 !important; }

    .al-step__text { padding: 28px 24px; }

    .al-step__img {
      height: 240px;
      border-left: none;
      border-right: none;
      border-bottom: 1px solid rgba(59, 142, 248, 0.25);
    }

    .al-step__heading { font-size: 1.375rem; }
  }
</style>

{% schema %}
{
  "name": "AL — How It Works",
  "tag": "section",
  "settings": [
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 20, "max": 120, "step": 4, "default": 20, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 20, "max": 120, "step": 4, "default": 20, "unit": "px" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Setup Guide" },
    { "type": "inline_richtext", "id": "heading", "label": "Section heading", "default": "Up and Running in 60 Seconds" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "No tools. No apps. No installation knowledge required." },
    { "type": "text", "id": "cta_label", "label": "CTA button label" },
    { "type": "url", "id": "cta_link", "label": "CTA button link" }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "inline_richtext", "id": "heading", "label": "Step heading", "default": "Plug In the Adapter" },
        { "type": "textarea", "id": "body", "label": "Step description", "default": "Connect the AutoLinkr adapter to your car's factory CarPlay USB port using the included cable. The adapter powers on automatically." },
        { "type": "text", "id": "badge", "label": "Badge label (optional)", "info": "e.g. '60 sec' or 'One time only'" },
        { "type": "text", "id": "image_url", "label": "Image CDN URL", "info": "Paste Shopify CDN URL directly (recommended)" },
        { "type": "image_picker", "id": "image", "label": "Or pick image from theme assets" },
        { "type": "select", "id": "image_ratio", "label": "Image aspect ratio", "options": [
            {"value": "4/3", "label": "4:3"},
            {"value": "16/9", "label": "16:9"},
            {"value": "1/1", "label": "Square"},
            {"value": "3/2", "label": "3:2"}
          ], "default": "4/3" }
      ]
    }
  ],
  "presets": [
    {
      "name": "AL — How It Works",
      "settings": {
        "eyebrow": "Setup Guide",
        "heading": "Up and Running in 60 Seconds",
        "subheading": "No tools. No apps. No installation knowledge required.",
        "cta_label": "Shop AutoLinkr Pro™",
        "cta_link": "/products/the-autolinkr-pro"
      }
    }
  ]
}
{% endschema %}
