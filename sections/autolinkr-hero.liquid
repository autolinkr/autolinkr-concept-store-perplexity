{% comment %}
  autolinkr-hero.liquid
  AutoLinkr Homepage Hero Section
  Phase A — ConceptThemePerplexity

  Layout:
  - Full-bleed dark section (BG: #0D0D0F)
  - Left column: headline, subheadline, CTAs, trust signals
  - Right column: product visual / video loop
  - Below fold: trust bar (icons + labels)
{% endcomment %}

{%- liquid
  assign hero_heading    = section.settings.hero_heading     | default: 'Wireless CarPlay.<br>Netflix. YouTube.<br>Your Car.'
  assign hero_sub        = section.settings.hero_sub         | default: 'Turn your wired CarPlay into wireless — and unlock streaming apps in seconds.'
  assign cta_primary_text= section.settings.cta_primary_text | default: 'Shop AutoLinkr Pro™'
  assign cta_primary_url = section.settings.cta_primary_url  | default: '/products/the-autolinkr-pro'
  assign cta_secondary_text= section.settings.cta_secondary_text | default: 'See How It Works'
  assign cta_secondary_url = section.settings.cta_secondary_url  | default: '#how-it-works'
  assign hero_price      = section.settings.hero_price       | default: '$79.99'
  assign hero_badge      = section.settings.hero_badge       | default: 'Free Shipping + 30-Day Returns'
  assign hero_image      = section.settings.hero_image
  assign hero_video_url  = section.settings.hero_video_url
  assign show_trust_bar  = section.settings.show_trust_bar
-%}

{{ 'autolinkr-hero.css' | asset_url | stylesheet_tag }}

<section
  class="al-hero"
  id="al-hero"
  aria-label="AutoLinkr Hero"
  data-section-id="{{ section.id }}"
  data-section-type="autolinkr-hero"
>

  {%- comment %} ── BACKGROUND GRID + GLOW ── {%- endcomment %}
  <div class="al-hero__bg" aria-hidden="true">
    <div class="al-hero__bg-grid"></div>
    <div class="al-hero__bg-glow al-hero__bg-glow--blue"></div>
    <div class="al-hero__bg-glow al-hero__bg-glow--amber"></div>
  </div>

  <div class="al-container al-hero__inner">

    {%- comment %} ── LEFT: COPY COLUMN ── {%- endcomment %}
    <div class="al-hero__copy">

      {%- comment %} Eyebrow badge {%- endcomment %}
      <div class="al-hero__eyebrow">
        <span class="al-badge al-badge--blue">
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <circle cx="6" cy="6" r="5" stroke="#2D7FF9" stroke-width="1.5"/>
            <path d="M4 6l1.5 1.5L8 4" stroke="#2D7FF9" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          #1 Wireless CarPlay Adapter
        </span>
        <span class="al-hero__rating">
          <span class="al-hero__stars" aria-label="4.9 out of 5 stars">
            ★★★★★
          </span>
          <span class="al-hero__review-count">4.9 (2,400+ reviews)</span>
        </span>
      </div>

      {%- comment %} Headline {%- endcomment %}
      <h1 class="al-hero__headline">
        {{- hero_heading -}}
      </h1>

      {%- comment %} Sub-headline {%- endcomment %}
      <p class="al-hero__sub">{{ hero_sub }}</p>

      {%- comment %} Price row {%- endcomment %}
      <div class="al-hero__price-row">
        <span class="al-hero__price">{{ hero_price }}</span>
        <span class="al-hero__price-badge">{{ hero_badge }}</span>
      </div>

      {%- comment %} CTA buttons {%- endcomment %}
      <div class="al-hero__ctas">
        <a
          href="{{ cta_primary_url }}"
          class="al-btn al-btn--primary al-btn--lg al-hero__cta-primary"
          data-cta="hero-primary"
        >
          {{ cta_primary_text }}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" class="al-btn__icon">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a
          href="{{ cta_secondary_url }}"
          class="al-btn al-btn--ghost al-btn--lg al-hero__cta-secondary"
          data-cta="hero-secondary"
        >
          {{ cta_secondary_text }}
        </a>
      </div>

      {%- comment %} Social proof micro-bar {%- endcomment %}
      <div class="al-hero__social-proof">
        <div class="al-hero__avatars" aria-hidden="true">
          <div class="al-hero__avatar al-hero__avatar--1"></div>
          <div class="al-hero__avatar al-hero__avatar--2"></div>
          <div class="al-hero__avatar al-hero__avatar--3"></div>
          <div class="al-hero__avatar al-hero__avatar--4"></div>
        </div>
        <p class="al-hero__social-text">
          <strong>10,000+</strong> drivers upgraded their ride this year
        </p>
      </div>

      {%- comment %} Upsell nudge → Elite {%- endcomment %}
      <div class="al-hero__upsell-nudge">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M7 1l1.5 4h4l-3.25 2.5 1.25 4L7 9.5 3.5 11.5l1.25-4L1.5 5h4L7 1z" fill="#FF9500"/>
        </svg>
        <span>Want split-screen?
          <a href="/products/autolinkr-elite" class="al-hero__upsell-link" data-cta="hero-elite-nudge">
            Upgrade to Elite™ — $199.99
          </a>
        </span>
      </div>

    </div><!-- /.al-hero__copy -->

    {%- comment %} ── RIGHT: VISUAL COLUMN ── {%- endcomment %}
    <div class="al-hero__visual" aria-hidden="true">

      {%- if hero_video_url != blank -%}
        <div class="al-hero__video-wrap">
          <video
            class="al-hero__video"
            autoplay
            muted
            loop
            playsinline
            preload="metadata"
          >
            <source src="{{ hero_video_url }}" type="video/mp4">
          </video>
        </div>
      {%- elsif hero_image != blank -%}
        <div class="al-hero__img-wrap">
          {{
            hero_image
            | image_url: width: 900
            | image_tag:
              class: 'al-hero__img',
              widths: '400, 600, 900',
              sizes: '(max-width: 767px) 90vw, 45vw',
              loading: 'eager',
              fetchpriority: 'high',
              alt: 'AutoLinkr Pro — Wireless CarPlay Adapter'
          }}
        </div>
      {%- else -%}
        {%- comment %} Placeholder product card when no image set {%- endcomment %}
        <div class="al-hero__placeholder">
          <div class="al-hero__placeholder-device">
            <div class="al-hero__placeholder-screen">
              <div class="al-hero__placeholder-icons">
                <div class="al-hero__placeholder-icon al-hero__placeholder-icon--netflix"></div>
                <div class="al-hero__placeholder-icon al-hero__placeholder-icon--youtube"></div>
                <div class="al-hero__placeholder-icon al-hero__placeholder-icon--maps"></div>
                <div class="al-hero__placeholder-icon al-hero__placeholder-icon--spotify"></div>
              </div>
              <p class="al-hero__placeholder-label">Your Car's New Screen</p>
            </div>
          </div>
          <div class="al-hero__placeholder-glow" aria-hidden="true"></div>
        </div>
      {%- endif -%}

      {%- comment %} Floating feature chips {%- endcomment %}
      <div class="al-hero__chips">
        <div class="al-hero__chip al-hero__chip--1">
          <span class="al-hero__chip-icon">▶</span>
          Netflix &amp; YouTube
        </div>
        <div class="al-hero__chip al-hero__chip--2">
          <span class="al-hero__chip-icon">📶</span>
          Plug-in &amp; Play
        </div>
        <div class="al-hero__chip al-hero__chip--3">
          <span class="al-hero__chip-icon">🏪</span>
          Google Play Store
        </div>
      </div>

    </div><!-- /.al-hero__visual -->

  </div><!-- /.al-hero__inner -->

  {%- comment %} ── TRUST BAR ── {%- endcomment %}
  {%- if show_trust_bar -%}
  <div class="al-hero__trust-bar">
    <div class="al-container">
      <ul class="al-trust-bar" role="list">

        <li class="al-trust-bar__item">
          <svg class="al-trust-bar__icon" width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
            <path d="M11 2L4 5.5V10c0 4.1 3 7.9 7 9 4-1.1 7-4.9 7-9V5.5L11 2z" stroke="#30D158" stroke-width="1.5" stroke-linejoin="round"/>
            <path d="M7.5 11l2.5 2.5 5-5" stroke="#30D158" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>30-Day Money-Back Guarantee</span>
        </li>

        <li class="al-trust-bar__item">
          <svg class="al-trust-bar__icon" width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
            <path d="M3 8h16M3 8l2-4h10l2 4M3 8v8a1 1 0 001 1h14a1 1 0 001-1V8" stroke="#2D7FF9" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M9 16v-4h4v4" stroke="#2D7FF9" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <span>Free Shipping on All Orders</span>
        </li>

        <li class="al-trust-bar__item">
          <svg class="al-trust-bar__icon" width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
            <circle cx="11" cy="11" r="8" stroke="#FF9500" stroke-width="1.5"/>
            <path d="M8 11l2 2 4-4" stroke="#FF9500" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>Works with Your Existing CarPlay</span>
        </li>

        <li class="al-trust-bar__item">
          <svg class="al-trust-bar__icon" width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
            <path d="M11 2l2 6h6l-5 3.6 1.9 5.8L11 14l-4.9 3.4L8 11.6 3 8h6z" stroke="#F5F5F7" stroke-width="1.5" stroke-linejoin="round"/>
          </svg>
          <span>4.9 ★ — 2,400+ Verified Reviews</span>
        </li>

        <li class="al-trust-bar__item">
          <svg class="al-trust-bar__icon" width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
            <rect x="4" y="7" width="14" height="10" rx="1.5" stroke="#A1A1A6" stroke-width="1.5"/>
            <path d="M8 7V5.5a3 3 0 016 0V7" stroke="#A1A1A6" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <span>Secure Checkout</span>
        </li>

      </ul>
    </div>
  </div>
  {%- endif -%}

</section>

{% schema %}
{
  "name": "AutoLinkr Hero",
  "tag": "section",
  "class": "al-hero-section",
  "settings": [
    {
      "type": "text",
      "id": "hero_heading",
      "label": "Hero Headline",
      "default": "Wireless CarPlay.<br>Netflix. YouTube.<br>Your Car."
    },
    {
      "type": "textarea",
      "id": "hero_sub",
      "label": "Sub-headline",
      "default": "Turn your wired CarPlay into wireless — and unlock streaming apps in seconds."
    },
    {
      "type": "text",
      "id": "cta_primary_text",
      "label": "Primary CTA Text",
      "default": "Shop AutoLinkr Pro™"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "Primary CTA URL"
    },
    {
      "type": "text",
      "id": "cta_secondary_text",
      "label": "Secondary CTA Text",
      "default": "See How It Works"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Secondary CTA URL"
    },
    {
      "type": "text",
      "id": "hero_price",
      "label": "Price Display",
      "default": "$79.99"
    },
    {
      "type": "text",
      "id": "hero_badge",
      "label": "Price Badge Text",
      "default": "Free Shipping + 30-Day Returns"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Product Image"
    },
    {
      "type": "text",
      "id": "hero_video_url",
      "label": "Hero Video URL (MP4, overrides image)"
    },
    {
      "type": "checkbox",
      "id": "show_trust_bar",
      "label": "Show Trust Bar",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "AutoLinkr Hero"
    }
  ]
}
{% endschema %}
