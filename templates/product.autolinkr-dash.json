    "faq-section": {
      "type": "faq",
      "blocks": {
        "q1": {
          "type": "question",
          "settings": {
            "title": "Does the AutoLinkr Dash work with my car?",
            "text": "<p>Yes — the AutoLinkr Dash is universal and works with any vehicle that has a 12V power outlet (cigarette lighter). No wiring or installation knowledge required.</p>"
          }
        },
        "q2": {
          "type": "question",
          "settings": {
            "title": "What size SD card do I need?",
            "text": "<p>We recommend a Class 10 microSD card. You can choose a 32GB or 64GB card when purchasing, or select 'No SD Card' to use your own. A 32GB card holds approximately 4-6 hours of 1080P footage before loop recording overwrites old files.</p>"
          }
        },
        "q3": {
          "type": "question",
          "settings": {
            "title": "Does it record when the car is parked?",
            "text": "<p>Yes — parking mode uses motion detection to record when movement is detected near your vehicle. Requires the camera to be hardwired for constant power, or using the included 12V adapter which powers off when the car is off.</p>"
          }
        },
        "q4": {
          "type": "question",
          "settings": {
            "title": "How do I view my footage?",
            "text": "<p>Three ways: (1) Download the free AutoLinkr WiFi app on iOS or Android and connect to the camera's WiFi hotspot. (2) Remove the SD card and insert into any card reader. (3) View directly on the camera's built-in screen.</p>"
          }
        }
      },
      "block_order": [
        "q1",
        "q2",
        "q3",
        "q4"
