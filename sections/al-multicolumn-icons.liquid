{% comment %}
  AutoLinkr — Premium Feature Grid
  Dark, polished multi-column feature section with app icons + custom icons.
  Designed to showcase AutoLinkr Pro's core capabilities with authority.
{% endcomment %}

<section class="al-feat" style="
  padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  background: rgb(var(--color-base-background));
">
  <div class="page-width">

    {%- comment -%} Header {%- endcomment -%}
    <div class="al-feat__header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="al-feat__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="al-feat__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="al-feat__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} Feature grid {%- endcomment -%}
    <div class="al-feat__grid al-feat__grid--{{ section.blocks.size }}">
      {%- for block in section.blocks -%}
        {%- if block.type == 'feature' -%}
          <div class="al-feat__card" {{ block.shopify_attributes }}>

            {%- comment -%} Icon — either image or inline SVG {%- endcomment -%}
            <div class="al-feat__icon-wrap">
              {%- if block.settings.icon_image != blank -%}
                <img
                  src="{{ block.settings.icon_image | image_url: width: 80 }}"
                  alt="{{ block.settings.heading | escape }}"
                  width="48"
                  height="48"
                  loading="lazy"
                  class="al-feat__icon-img"
                >
              {%- else -%}
                <div class="al-feat__icon-svg">
                  {%- case block.settings.icon -%}
                    {%- when 'wireless' -%}
                      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M5 12.55a11 11 0 0 1 14.08 0" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
                        <path d="M1.42 9a16 16 0 0 1 21.16 0" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
                        <path d="M8.53 16.11a6 6 0 0 1 6.95 0" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
                        <circle cx="12" cy="20" r="1.5" fill="currentColor"/>
                      </svg>
                    {%- when 'play' -%}
                      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="2" y="3" width="20" height="14" rx="3" stroke="currentColor" stroke-width="1.75"/>
                        <path d="M8 21h8M12 17v4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
                        <path d="M10 8.5l5 3-5 3V8.5z" fill="currentColor"/>
                      </svg>
                    {%- when 'bolt' -%}
                      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M13 2L4.09 12.37A1 1 0 0 0 4.85 14H11l-2 8 8.91-10.37A1 1 0 0 0 17.15 10H11l2-8z" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    {%- when 'shield' -%}
                      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 2L3 7v5c0 5.25 3.75 10.15 9 11.25C17.25 22.15 21 17.25 21 12V7L12 2z" stroke="currentColor" stroke-width="1.75" stroke-linejoin="round"/>
                        <path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    {%- when 'connect' -%}
                      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.75"/>
                        <path d="M12 2v3M12 19v3M2 12h3M19 12h3" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
                        <path d="M5.64 5.64l2.12 2.12M16.24 16.24l2.12 2.12M5.64 18.36l2.12-2.12M16.24 7.76l2.12-2.12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
                      </svg>
                    {%- when 'download' -%}
                      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 3v13M8 12l4 4 4-4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M3 17v2a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-2" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
                      </svg>
                    {%- else -%}
                      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.75"/>
                        <path d="M12 8v4l3 3" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
                      </svg>
                  {%- endcase -%}
                </div>
              {%- endif -%}
            </div>

            <div class="al-feat__card-body">
              {%- if block.settings.heading != blank -%}
                <h3 class="al-feat__card-heading">{{ block.settings.heading }}</h3>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <p class="al-feat__card-text">{{ block.settings.text }}</p>
              {%- endif -%}

              {%- comment -%} App icon strip — shown on streaming-type cards {%- endcomment -%}
              {%- if block.settings.show_app_icons -%}
                <div class="al-feat__apps">
                  {%- if block.settings.app_icon_1 != blank -%}
                    <img src="{{ block.settings.app_icon_1 | image_url: width: 56 }}" alt="App" width="28" height="28" loading="lazy" class="al-feat__app-icon">
                  {%- endif -%}
                  {%- if block.settings.app_icon_2 != blank -%}
                    <img src="{{ block.settings.app_icon_2 | image_url: width: 56 }}" alt="App" width="28" height="28" loading="lazy" class="al-feat__app-icon">
                  {%- endif -%}
                  {%- if block.settings.app_icon_3 != blank -%}
                    <img src="{{ block.settings.app_icon_3 | image_url: width: 56 }}" alt="App" width="28" height="28" loading="lazy" class="al-feat__app-icon">
                  {%- endif -%}
                  {%- if block.settings.app_icon_4 != blank -%}
                    <img src="{{ block.settings.app_icon_4 | image_url: width: 56 }}" alt="App" width="28" height="28" loading="lazy" class="al-feat__app-icon">
                  {%- endif -%}
                  {%- if block.settings.app_icon_5 != blank -%}
                    <img src="{{ block.settings.app_icon_5 | image_url: width: 56 }}" alt="App" width="28" height="28" loading="lazy" class="al-feat__app-icon">
                  {%- endif -%}
                </div>
              {%- endif -%}
            </div>

          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

<style>
  /* ── Section wrapper ── */
  .al-feat .page-width {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
  }

  /* ── Header ── */
  .al-feat__header {
    text-align: center;
    margin-bottom: 64px;
  }

  .al-feat__eyebrow {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(59,142,248,0.85);
    margin-bottom: 18px;
  }

  .al-feat__heading {
    font-family: var(--al-font-display, 'General Sans', sans-serif);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    color: #fff;
    line-height: 1.0;
    letter-spacing: -0.04em;
    margin: 0 auto 20px;
    max-width: 760px;
  }

  .al-feat__subheading {
    font-size: 1.0625rem;
    color: rgba(255,255,255,0.5);
    max-width: 520px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* ── Grid ── */
  .al-feat__grid {
    display: grid;
    gap: 2px;
    background: rgba(59,142,248,0.12);
    border: 1px solid rgba(59,142,248,0.2);
    border-radius: 24px;
    overflow: hidden;
  }

  /* 6 cards → 3 col */
  .al-feat__grid--6 { grid-template-columns: repeat(3, 1fr); }
  /* 4 cards → 2 col */
  .al-feat__grid--4 { grid-template-columns: repeat(2, 1fr); }
  /* 3 cards → 3 col */
  .al-feat__grid--3 { grid-template-columns: repeat(3, 1fr); }

  /* ── Card ── */
  .al-feat__card {
    background: #0F0F12;
    padding: 40px 36px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    position: relative;
    transition: background 0.2s ease;
  }

  .al-feat__card:hover {
    background: #131318;
  }

  /* Top-left accent corner on hover */
  .al-feat__card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 2px; height: 0;
    background: rgba(59,142,248,0.9);
    transition: height 0.3s ease;
  }
  .al-feat__card:hover::before { height: 48px; }

  /* ── Icon wrap ── */
  .al-feat__icon-wrap {
    width: 52px;
    height: 52px;
    flex-shrink: 0;
  }

  .al-feat__icon-svg {
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(59,142,248,0.1);
    border: 1px solid rgba(59,142,248,0.2);
    border-radius: 14px;
    color: rgba(59,142,248,1);
  }

  .al-feat__icon-svg svg {
    width: 24px;
    height: 24px;
  }

  .al-feat__icon-img {
    width: 52px;
    height: 52px;
    object-fit: contain;
    border-radius: 14px;
  }

  /* ── Card body ── */
  .al-feat__card-body {
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }

  .al-feat__card-heading {
    font-family: var(--al-font-display, 'General Sans', sans-serif);
    font-size: 1.0625rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.25;
    margin: 0;
    letter-spacing: -0.01em;
  }

  .al-feat__card-text {
    font-size: 0.9rem;
    line-height: 1.65;
    color: rgba(255,255,255,0.5);
    margin: 0;
  }

  /* ── App icon strip ── */
  .al-feat__apps {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 6px;
  }

  .al-feat__app-icon {
    width: 28px;
    height: 28px;
    object-fit: contain;
    border-radius: 7px;
    opacity: 0.85;
    transition: opacity 0.15s;
  }

  .al-feat__app-icon:hover { opacity: 1; }

  /* ── Mobile ── */
  @media (max-width: 900px) {
    .al-feat__grid--6,
    .al-feat__grid--4 { grid-template-columns: repeat(2, 1fr); }
    .al-feat__card { padding: 32px 28px; }
    .al-feat__heading { font-size: 2.5rem; }
  }

  @media (max-width: 580px) {
    .al-feat__grid--6,
    .al-feat__grid--4,
    .al-feat__grid--3 { grid-template-columns: 1fr; }
    .al-feat .page-width { padding: 0 20px; }
    .al-feat__header { margin-bottom: 40px; }
    .al-feat__card { padding: 28px 24px; }
  }
</style>

{% schema %}
{
  "name": "AL — Feature Grid",
  "tag": "section",
  "settings": [
    { "type": "text",  "id": "eyebrow",    "label": "Eyebrow",    "default": "Why AutoLinkr Pro" },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Everything You Need. Nothing You Don't." },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },
    { "type": "range", "id": "padding_top",    "label": "Padding top",    "min": 20, "max": 140, "step": 4, "default": 96, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 20, "max": 140, "step": 4, "default": 96, "unit": "px" }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        { "type": "header", "content": "Icon" },
        { "type": "image_picker", "id": "icon_image", "label": "Custom icon image (overrides SVG icon)" },
        { "type": "select", "id": "icon", "label": "SVG icon (if no image)", "options": [
            { "value": "wireless",  "label": "Wireless signal" },
            { "value": "play",      "label": "Screen / Play" },
            { "value": "bolt",      "label": "Bolt / Speed" },
            { "value": "shield",    "label": "Shield / Security" },
            { "value": "connect",   "label": "Connect / Hub" },
            { "value": "download",  "label": "Download" }
          ],
          "default": "wireless"
        },
        { "type": "header", "content": "Content" },
        { "type": "text",     "id": "heading", "label": "Heading" },
        { "type": "textarea", "id": "text",    "label": "Description" },
        { "type": "header", "content": "App Icons (optional)" },
        { "type": "checkbox",    "id": "show_app_icons", "label": "Show app icons", "default": false },
        { "type": "image_picker", "id": "app_icon_1", "label": "App icon 1" },
        { "type": "image_picker", "id": "app_icon_2", "label": "App icon 2" },
        { "type": "image_picker", "id": "app_icon_3", "label": "App icon 3" },
        { "type": "image_picker", "id": "app_icon_4", "label": "App icon 4" },
        { "type": "image_picker", "id": "app_icon_5", "label": "App icon 5" }
      ]
    }
  ],
  "presets": [
    {
      "name": "AL — Feature Grid",
      "settings": {
        "eyebrow": "Why AutoLinkr Pro",
        "heading": "Everything You Need. Nothing You Don't.",
        "subheading": "Six reasons tens of thousands of drivers upgraded their drive."
      },
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "wireless",
            "heading": "Wireless CarPlay & Android Auto",
            "text": "No cables. Connects automatically every drive. Just get in and go."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "play",
            "heading": "Netflix, YouTube & Disney+",
            "text": "Stream any app directly on your factory screen via the Google Play Store.",
            "show_app_icons": false
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "bolt",
            "heading": "60-Second Setup",
            "text": "No tools, no mechanic, no wiring. Plug in once — auto-connects every drive after."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "shield",
            "heading": "500+ Compatible Vehicles",
            "text": "Toyota, Honda, Ford, BMW, and 30+ more brands. 2016+ with factory CarPlay."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "connect",
            "heading": "Auto-Connects on Start",
            "text": "Get in your car and it just works. No buttons, no pairing — every single drive."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "download",
            "heading": "Offline Downloads",
            "text": "Download shows before your trip. Micro SD expandable storage — no data needed."
          }
        }
      ]
    }
  ],
  "disabled_on": { "groups": ["footer", "header", "custom.overlay"] }
}
{% endschema %}
