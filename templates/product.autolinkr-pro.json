            "show_price": true,
            "show_rating": true
          }
        },
        "text-tagline": {
          "type": "text",
          "settings": {
            "text": "Converts your wired CarPlay to wireless — plus Netflix, YouTube & Google Play on your factory screen. No cables. No setup. Just drive.",
            "text_size": "text-base",
            "icon": "none"
          }
        },
        "variant_picker": {
          "type": "variant_picker",
          "settings": {
            "enable_dynamic_variants": true,
            "show_variant_labels": true,
            "picker_type": "button",
