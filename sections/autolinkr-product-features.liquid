{% comment %}
  autolinkr-product-features.liquid
  AutoLinkr Product Page — Features & Details Block
  Phase B — ConceptThemePerplexity

  Renders (all product-aware, handle-driven):
  - Specs table
  - Compatibility checker
  - What's in the box
  - FAQ accordion
  - Cross-sell strip ("Pair it with")
{% endcomment %}

{%- liquid
  assign product = product
  assign is_pro    = false
  assign is_elite  = false
  assign is_base   = false
  assign is_dash   = false
  assign is_tablet = false
  if product.handle == 'the-autolinkr-pro' or product.handle == 'shop-the-autolinkr-pro'
    assign is_pro = true
  endif
  if product.handle == 'autolinkr-elite'
    assign is_elite = true
  endif
  if product.handle == 'autolinkr-base'
    assign is_base = true
  endif
  if product.handle == 'autolinkr-dash'
    assign is_dash = true
  endif
  if product.handle == 'autolinkr-tablet'
    assign is_tablet = true
  endif
-%}

<section
  class="al-pdp-features"
  data-section-id="{{ section.id }}"
  data-section-type="autolinkr-product-features"
>
  <div class="al-container">

    {%- comment %} ── SPECS TABLE ── {%- endcomment %}
    <div class="al-pdp-specs">
      <h2 class="al-pdp-specs__title">Technical Specifications</h2>
      <table class="al-pdp-specs__table" role="table">
        <tbody>

          {%- if is_pro or is_elite or is_base -%}
            <tr>
              <th scope="row">Connectivity</th>
              <td>Wi-Fi 5GHz + Bluetooth 5.0</td>
            </tr>
            <tr>
              <th scope="row">Compatible With</th>
              <td>Factory wired CarPlay{%- if is_base -%} or Android Auto{%- endif -%}</td>
            </tr>
            <tr>
              <th scope="row">Wireless Standard</th>
              <td>802.11ac (5 GHz)</td>
            </tr>
            {%- if is_pro or is_elite -%}
            <tr>
              <th scope="row">App Store</th>
              <td>Google Play (Netflix, YouTube, Spotify, Chrome…)</td>
            </tr>
            {%- endif -%}
            {%- if is_elite -%}
            <tr>
              <th scope="row">Split Screen</th>
              <td>Yes — navigate + stream simultaneously</td>
            </tr>
            <tr>
              <th scope="row">Processor</th>
              <td>Octa-core 2.0 GHz (Elite exclusive)</td>
            </tr>
            {%- endif -%}
            <tr>
              <th scope="row">Setup Time</th>
              <td>Under 3 minutes (plug in, pair once)</td>
            </tr>
            <tr>
              <th scope="row">Power</th>
              <td>USB-A port in vehicle (no additional power required)</td>
            </tr>
            <tr>
              <th scope="row">Dimensions</th>
              <td>85 × 55 × 12 mm</td>
            </tr>
            <tr>
              <th scope="row">Warranty</th>
              <td>1 Year (US)</td>
            </tr>
          {%- endif -%}

          {%- if is_dash -%}
            <tr>
              <th scope="row">Resolution</th>
              <td>Dual 1080P Full HD (front + cabin)</td>
            </tr>
            <tr>
              <th scope="row">Night Vision</th>
              <td>IR LEDs — cabin night vision</td>
            </tr>
            <tr>
              <th scope="row">Field of View</th>
              <td>170° ultra-wide front lens</td>
            </tr>
            <tr>
              <th scope="row">Storage</th>
              <td>microSD up to 256 GB (not included)</td>
            </tr>
            <tr>
              <th scope="row">App</th>
              <td>WiFi direct — iOS & Android</td>
            </tr>
            <tr>
              <th scope="row">G-Sensor</th>
              <td>Yes — auto event lock on impact</td>
            </tr>
            <tr>
              <th scope="row">Loop Recording</th>
              <td>Yes — overwrites oldest footage</td>
            </tr>
            <tr>
              <th scope="row">Parking Mode</th>
              <td>Yes (requires hardwire kit, sold separately)</td>
            </tr>
            <tr>
              <th scope="row">Power</th>
              <td>12V / 24V via included OBD / USB adapter</td>
            </tr>
          {%- endif -%}

          {%- if is_tablet -%}
            <tr>
              <th scope="row">Screen Size</th>
              <td>7" IPS touchscreen</td>
            </tr>
            <tr>
              <th scope="row">Resolution</th>
              <td>1024 × 600</td>
            </tr>
            <tr>
              <th scope="row">Wireless Protocol</th>
              <td>Bluetooth 5.0 + Wi-Fi 5 GHz</td>
            </tr>
            <tr>
              <th scope="row">CarPlay</th>
              <td>Wireless (iPhone only for CarPlay)</td>
            </tr>
            <tr>
              <th scope="row">Android Auto</th>
              <td>Wireless (Android phones)</td>
            </tr>
            <tr>
              <th scope="row">Mount</th>
              <td>Suction cup (included)</td>
            </tr>
            <tr>
              <th scope="row">Power</th>
              <td>12V cigarette lighter (included)</td>
            </tr>
            <tr>
              <th scope="row">Battery</th>
              <td>Built-in 2000 mAh (30 min unplugged)</td>
            </tr>
          {%- endif -%}

        </tbody>
      </table>
    </div><!-- /.al-pdp-specs -->

    {%- comment %} ── COMPATIBILITY CHECKER ── {%- endcomment %}
    {%- if is_pro or is_elite or is_base -%}
    <div class="al-pdp-compat">
      <h2 class="al-pdp-compat__title">Is My Car Compatible?</h2>
      <p class="al-pdp-compat__desc">
        AutoLinkr works with any vehicle that has a <strong>factory wired CarPlay{%- if is_base -%} or Android Auto{%- endif -%}</strong> port.
        Check your car's infotainment below:
      </p>

      <div class="al-pdp-compat__grid">
        {%- assign compat_makes = 'Toyota,Honda,Ford,Chevrolet,BMW,Mercedes-Benz,Volkswagen,Audi,Hyundai,Kia,Subaru,Mazda,Nissan,Ram,Jeep' | split: ',' -%}
        {%- for make in compat_makes -%}
          <div class="al-pdp-compat__chip">
            {{ make }}
          </div>
        {%- endfor -%}
        <div class="al-pdp-compat__chip al-pdp-compat__chip--more">+ 200 more makes</div>
      </div>

      <p class="al-pdp-compat__note">
        Not sure? <a href="/pages/compatibility" class="al-link">Check the full compatibility list →</a>
      </p>
    </div>
    {%- endif -%}

    {%- comment %} ── WHAT'S IN THE BOX ── {%- endcomment %}
    <div class="al-pdp-box">
      <h2 class="al-pdp-box__title">What's in the Box</h2>
      <ul class="al-pdp-box__list" role="list">
        {%- if is_pro or is_elite or is_base -%}
          <li class="al-pdp-box__item">AutoLinkr {%- if is_pro -%} Pro{%- elsif is_elite -%} Elite{%- else -%} Base{%- endif -%} dongle</li>
          <li class="al-pdp-box__item">USB-A cable (1 m)</li>
          <li class="al-pdp-box__item">Quick-start guide</li>
          {%- if is_elite -%}
          <li class="al-pdp-box__item">USB-C power adapter</li>
          {%- endif -%}
        {%- endif -%}
        {%- if is_dash -%}
          <li class="al-pdp-box__item">Front camera unit</li>
          <li class="al-pdp-box__item">Cabin camera unit + cable</li>
          <li class="al-pdp-box__item">OBD power adapter</li>
          <li class="al-pdp-box__item">3M adhesive mounts (×2)</li>
          <li class="al-pdp-box__item">Quick-start guide</li>
        {%- endif -%}
        {%- if is_tablet -%}
          <li class="al-pdp-box__item">7" wireless CarPlay/Android Auto screen</li>
          <li class="al-pdp-box__item">Suction cup dash mount</li>
          <li class="al-pdp-box__item">12V cigarette lighter power cable</li>
          <li class="al-pdp-box__item">Quick-start guide</li>
        {%- endif -%}
      </ul>
    </div><!-- /.al-pdp-box -->

    {%- comment %} ── FAQ ACCORDION ── {%- endcomment %}
    <div class="al-pdp-faq">
      <h2 class="al-pdp-faq__title">Frequently Asked Questions</h2>

      <div class="al-faq-list">

        {%- if is_pro or is_elite or is_base -%}

          <div class="al-faq-item">
            <button class="al-faq-item__trigger" aria-expanded="false">
              Does it work with my car?
              <svg class="al-faq-item__icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </button>
            <div class="al-faq-item__body">
              <p>AutoLinkr works with any vehicle that has a factory-installed wired CarPlay{%- if is_base -%} or Android Auto{%- endif -%} port. If your car came with a USB cable to connect your phone to CarPlay, AutoLinkr will work. Most 2017+ vehicles are supported.</p>
            </div>
          </div>

          <div class="al-faq-item">
            <button class="al-faq-item__trigger" aria-expanded="false">
              How long does setup take?
              <svg class="al-faq-item__icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </button>
            <div class="al-faq-item__body">
              <p>Under 3 minutes. Plug AutoLinkr into your USB port, enable Bluetooth on your phone, and pair once. Every time you get in the car, it connects automatically.</p>
            </div>
          </div>

          {%- if is_pro or is_elite -%}
          <div class="al-faq-item">
            <button class="al-faq-item__trigger" aria-expanded="false">
              Can I really watch Netflix on my car screen?
              <svg class="al-faq-item__icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </button>
            <div class="al-faq-item__body">
              <p>Yes. AutoLinkr Pro{%- if is_elite -%}/Elite{%- endif -%} includes Google Play, so you can install and run Netflix, YouTube, Disney+, and thousands of other Android apps directly on your factory screen. We recommend only using streaming apps when parked or as a passenger.</p>
            </div>
          </div>
          {%- endif -%}

          <div class="al-faq-item">
            <button class="al-faq-item__trigger" aria-expanded="false">
              Will it affect my warranty?
              <svg class="al-faq-item__icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </button>
            <div class="al-faq-item__body">
              <p>No. AutoLinkr is a plug-in accessory — it makes no permanent modifications to your vehicle. Simply unplug it at any time with no trace left behind.</p>
            </div>
          </div>

          <div class="al-faq-item">
            <button class="al-faq-item__trigger" aria-expanded="false">
              What's your return policy?
              <svg class="al-faq-item__icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </button>
            <div class="al-faq-item__body">
              <p>30-day free returns, no questions asked. If AutoLinkr doesn't work with your vehicle, contact support and we'll arrange a free pickup and full refund.</p>
            </div>
          </div>

        {%- endif -%}

        {%- if is_dash -%}

          <div class="al-faq-item">
            <button class="al-faq-item__trigger" aria-expanded="false">
              Does it record continuously?
              <svg class="al-faq-item__icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </button>
            <div class="al-faq-item__body">
              <p>Yes. AutoLinkr Dash records in continuous loop mode — when the card is full, it overwrites the oldest footage automatically. Incident clips are locked by the G-sensor and won't be overwritten.</p>
            </div>
          </div>

          <div class="al-faq-item">
            <button class="al-faq-item__trigger" aria-expanded="false">
              What SD card do I need?
              <svg class="al-faq-item__icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </button>
            <div class="al-faq-item__body">
              <p>Any Class 10 / U3 microSD card up to 256 GB. We recommend Samsung Endurance or SanDisk High Endurance cards for dashcam use. SD card is not included.</p>
            </div>
          </div>

          <div class="al-faq-item">
            <button class="al-faq-item__trigger" aria-expanded="false">
              How do I view footage?
              <svg class="al-faq-item__icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </button>
            <div class="al-faq-item__body">
              <p>Connect to the camera's WiFi hotspot and use the free AutoLinkr app (iOS & Android) to browse and download clips. You can also remove the SD card and plug it into a computer.</p>
            </div>
          </div>

        {%- endif -%}

        {%- if is_tablet -%}

          <div class="al-faq-item">
            <button class="al-faq-item__trigger" aria-expanded="false">
              Does my car need built-in CarPlay?
              <svg class="al-faq-item__icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </button>
            <div class="al-faq-item__body">
              <p>No. The AutoLinkr Tablet is a standalone 7" screen that brings CarPlay and Android Auto to any car — even older vehicles with no infotainment system at all. It runs independently via its own screen and power cable.</p>
            </div>
          </div>

          <div class="al-faq-item">
            <button class="al-faq-item__trigger" aria-expanded="false">
              Is it easy to install?
              <svg class="al-faq-item__icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </button>
            <div class="al-faq-item__body">
              <p>Yes. Mount the suction cup to your windshield or dash, plug the power cable into your cigarette lighter, and connect your phone via Bluetooth. Setup takes under 5 minutes.</p>
            </div>
          </div>

        {%- endif -%}

      </div><!-- /.al-faq-list -->
    </div><!-- /.al-pdp-faq -->

    {%- comment %} ── CROSS-SELL STRIP ── {%- endcomment %}
    {%- if section.settings.show_crosssell -%}
    <div class="al-pdp-crosssell">
      <h2 class="al-pdp-crosssell__title">Pair it With</h2>
      <div class="al-pdp-crosssell__grid">
        {%- assign crosssell_handles = section.settings.crosssell_products | split: ',' -%}
        {%- for handle in crosssell_handles -%}
          {%- assign cs_product = all_products[handle | strip] -%}
          {%- if cs_product != empty -%}
          <div class="al-pdp-crosssell__card">
            {%- if cs_product.featured_image -%}
              <a href="{{ cs_product.url }}" class="al-pdp-crosssell__img-wrap">
                {{
                  cs_product.featured_image
                  | image_url: width: 300
                  | image_tag:
                    class: 'al-pdp-crosssell__img',
                    widths: '200, 300',
                    loading: 'lazy',
                    alt: cs_product.title
                }}
              </a>
            {%- endif -%}
            <div class="al-pdp-crosssell__info">
              <a href="{{ cs_product.url }}" class="al-pdp-crosssell__name">{{ cs_product.title }}</a>
              <span class="al-pdp-crosssell__price">{{ cs_product.price | money }}</span>
            </div>
            <a href="{{ cs_product.url }}" class="al-btn al-btn--ghost al-btn--sm al-pdp-crosssell__btn">View →</a>
          </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
    {%- endif -%}

  </div><!-- /.al-container -->
</section>

{% schema %}
{
  "name": "AutoLinkr Product Features",
  "tag": "section",
  "class": "section-autolinkr-product-features",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_crosssell",
      "label": "Show cross-sell strip",
      "default": true
    },
    {
      "type": "text",
      "id": "crosssell_products",
      "label": "Cross-sell product handles",
      "info": "Comma-separated product handles. Example: autolinkr-dash,autolinkr-tablet",
      "default": "autolinkr-dash,autolinkr-tablet"
    }
  ],
  "presets": [
    {
      "name": "AutoLinkr Product Features"
    }
  ]
}
{% endschema %}
