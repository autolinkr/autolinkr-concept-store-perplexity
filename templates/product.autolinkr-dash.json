    "multicolumn-features": {
      "type": "multicolumn-with-icons",
      "blocks": {
        "col-1": {
          "type": "column",
          "settings": {
            "icon": "eye",
            "heading": "Dual 1080P Recording",
            "text": "<p>Front and rear cameras both capture full 1080P HD — crystal-clear footage in any incident, day or night.</p>"
          }
        },
        "col-2": {
          "type": "column",
          "settings": {
            "icon": "moon",
            "heading": "IR Night Vision",
            "text": "<p>Infrared night vision captures clear footage in complete darkness. Most dash cams go black at night — not this one.</p>"
          }
        },
        "col-3": {
          "type": "column",
          "settings": {
            "icon": "search",
            "heading": "170° Ultra-Wide Lens",
            "text": "<p>Capture lane changes, side-impact risks, and pedestrians. The 170° angle sees everything in front of your vehicle.</p>"
          }
        },
        "col-4": {
          "type": "column",
          "settings": {
            "icon": "wifi",
            "heading": "WiFi App Control",
            "text": "<p>View live footage, download clips, and adjust settings directly from your phone using the free AutoLinkr app.</p>"
          }
        },
        "col-5": {
          "type": "column",
          "settings": {
            "icon": "lock",
            "heading": "G-Sensor Protection",
            "text": "<p>Detects collisions and hard braking — automatically locks that footage so it can't be overwritten by loop recording.</p>"
          }
        },
        "col-6": {
          "type": "column",
          "settings": {
            "icon": "refresh",
            "heading": "Loop Recording",
            "text": "<p>Continuously records and automatically overwrites oldest files when the SD card is full. Set it and forget it — always recording.</p>"
          }
        }
      },
      "block_order": [
        "col-1",
        "col-2",
        "col-3",
        "col-4",
        "col-5",
        "col-6"
