        "buy_buttons": {
          "type": "buy_buttons",
          "settings": {
            "show_quantity_selector": true,
            "show_price": true,
            "show_dynamic_checkout": true,
            "show_gift_card_recipient": false,
            "enable_back_in_stock": true,
