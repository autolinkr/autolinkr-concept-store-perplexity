        "text-trust-2": {
          "type": "text",
          "settings": {
            "text": "✓ 30-Day Money-Back Guarantee",
            "text_size": "text-sm",
            "icon": "none"
          }
        },
        "text-trust-3": {
          "type": "text",
          "settings": {
            "text": "✓ 1-Year Warranty — 50,000+ Happy Drivers",
            "text_size": "text-sm",
            "icon": "none"
          }
        },
        "collapsible-whats-included": {
          "type": "collapsible_tab",
          "settings": {
            "opened": true,
            "style": "with-border",
            "heading": "What's Included",
            "content": "<ul><li>AutoLinkr Pro™ Adapter</li><li>USB-A to USB-C Cable</li><li>USB-C to USB-C Cable</li><li>Quick-Start Guide</li></ul>",
            "text_size": "text-sm"
          }
        },
        "collapsible-works-with": {
          "type": "collapsible_tab",
          "settings": {
            "opened": false,
            "style": "with-border",
            "heading": "Will This Work With My Car?",
            "content": "<p><strong>Supports 97%+ of vehicles with factory wired CarPlay.</strong></p><p>Requirements:</p><ul><li>✔ Model Year 2016 or newer</li><li>✔ Factory-installed wired Apple CarPlay</li><li>✔ iPhone 7 or newer (iOS 10+)</li></ul><p>Works with BMW, Mercedes, Honda, Toyota, Ford, Chevy, Audi, VW, Hyundai, Kia, and 100+ other makes.</p><p><em>Note: AutoLinkr Pro™ does NOT add CarPlay to vehicles that don't already have it factory-installed.</em></p>",
            "text_size": "text-sm"
          }
        },
        "collapsible-streaming": {
          "type": "collapsible_tab",
          "settings": {
            "opened": false,
            "style": "with-border",
            "heading": "Streaming Apps Unlocked",
            "content": "<p>AutoLinkr Pro™ gives your factory CarPlay screen full streaming access:</p><ul><li>Netflix</li><li>YouTube</li><li>Google Play Store (download any app)</li><li>Hulu, Disney+, Amazon Prime Video</li><li>Spotify, Apple Music, Pandora</li><li>Waze, Google Maps</li><li>TikTok, ESPN, and more</li></ul><p><em>An internet/data connection is required for streaming apps.</em></p>",
            "text_size": "text-sm"
          }
        },
        "collapsible-shipping": {
          "type": "collapsible_tab",
          "settings": {
            "opened": false,
            "style": "with-border",
            "heading": "Shipping & Returns",
            "content": "<p>Shipping on this item is <strong>FREE</strong>! Orders ship within 1–2 business days. Most US customers receive delivery within 3–5 business days.</p><p><strong>30-Day Money-Back Guarantee</strong> — If you're not completely satisfied, return it for a full refund, no questions asked. <strong>1-Year Warranty</strong> on all manufacturing defects.</p>",
            "text_size": "text-sm"
          }
        },
        "rating": {
          "type": "rating",
          "settings": {}
        }
      },
