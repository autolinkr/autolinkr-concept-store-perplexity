        "collapsible-elite-vs-pro": {
          "type": "collapsible_tab",
          "settings": {
            "opened": true,
            "style": "with-border",
            "heading": "Elite vs Pro \u2014 What's the Difference?",
            "content": "<ul><li><strong>Split-Screen:</strong> Elite only \u2014 navigate and stream on one screen simultaneously</li><li><strong>Faster CPU:</strong> Elite uses a more powerful processor for smoother multitasking</li><li><strong>Streaming:</strong> Both support Netflix, YouTube, Google Play</li><li><strong>Wireless CarPlay:</strong> Both convert your factory wired CarPlay to wireless</li><li><strong>Setup:</strong> Both connect in under 60 seconds, auto-connect on every future drive</li></ul><p>If you want the absolute best experience \u2014 with zero compromises \u2014 Elite is your answer.</p>",
            "text_size": "text-sm"
          }
        },
        "collapsible-whats-included": {
          "type": "collapsible_tab",
          "settings": {
            "opened": false,
            "style": "with-border",
            "heading": "What's Included",
            "content": "<ul><li>AutoLinkr Elite\u2122 Adapter</li><li>USB-A to USB-C Cable</li><li>USB-C to USB-C Cable</li><li>Quick-Start Guide</li></ul>",
            "text_size": "text-sm"
          }
        },
        "collapsible-works-with": {
          "type": "collapsible_tab",
          "settings": {
            "opened": false,
            "style": "with-border",
            "heading": "Will This Work With My Car?",
            "content": "<p><strong>Supports 97%+ of vehicles with factory wired CarPlay.</strong></p><p>Requirements:</p><ul><li>\u2714 Model Year 2016 or newer</li><li>\u2714 Factory-installed wired Apple CarPlay</li><li>\u2714 iPhone 7 or newer (iOS 10+)</li></ul><p>Works with BMW, Mercedes, Honda, Toyota, Ford, Chevy, Audi, VW, Hyundai, Kia, and 100+ other makes.</p><p><em>Note: AutoLinkr Elite\u2122 does NOT add CarPlay to vehicles that don't already have it factory-installed.</em></p>",
            "text_size": "text-sm"
          }
        },
        "collapsible-streaming": {
          "type": "collapsible_tab",
          "settings": {
            "opened": false,
            "style": "with-border",
            "heading": "Streaming Apps Unlocked",
            "content": "<p>AutoLinkr Elite\u2122 gives your factory CarPlay screen full streaming access:</p><ul><li>Netflix</li><li>YouTube</li><li>Google Play Store (download any app)</li><li>Hulu, Disney+, Amazon Prime Video</li><li>Spotify, Apple Music, Pandora</li><li>Waze, Google Maps (simultaneously with streaming)</li><li>TikTok, ESPN, and more</li></ul><p><em>An internet/data connection is required for streaming apps.</em></p>",
            "text_size": "text-sm"
          }
        },
        "collapsible-shipping": {
          "type": "collapsible_tab",
          "settings": {
            "opened": false,
            "style": "with-border",
            "heading": "Shipping, Returns & Guarantee",
            "content": "<p>Shipping is <strong>FREE</strong> on every order. Ships within 1\u20132 business days, delivered in 3\u20135 business days for most US customers.</p><p><strong>30-Day Guarantee</strong> \u2014 You have 30 days from the date you receive your unit to return it. No questions asked, no hassle.</p><p><strong>1-Year Warranty</strong> \u2014 Covered against all manufacturing defects.</p>",
            "text_size": "text-sm"
          }
        },
