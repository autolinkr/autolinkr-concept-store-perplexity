{% comment %}
  AutoLinkr Video Section
  Dark-themed full-width video embed (CDN .mov/.mp4 or YouTube)
  Supports: eyebrow label, heading, subheading, CTA button, video poster
{% endcomment %}

{%- liquid
  assign bg_class = 'al-vid-section'
  if section.settings.background_style == 'surface'
    assign bg_class = 'al-vid-section al-vid-section--surface'
  endif
-%}

<section
  class="{{ bg_class }}"
  style="padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;"
>
  <div
    class="al-vid-section__inner page-width"
    style="max-width: {{ section.settings.max_width }}px; margin: 0 auto; padding: 0 24px;"
  >

    {%- if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.subheading != blank -%}
      <div
        class="al-vid-section__header"
        style="text-align: {{ section.settings.text_align }};"
      >
        {%- if section.settings.eyebrow != blank -%}
          <span class="al-label">{{ section.settings.eyebrow }}</span>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <{{ section.settings.heading_tag }}
            class="al-vid-section__heading"
            style="margin-top: 14px;"
          >{{ section.settings.heading }}</{{ section.settings.heading_tag }}>
        {%- endif -%}

        {%- if section.settings.subheading != blank -%}
          <p class="al-vid-section__sub" style="margin-top: 10px;">
            {{ section.settings.subheading | escape }}
          </p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.settings.youtube_id != blank -%}
      <!-- YouTube embed -->
      <div
        class="al-youtube-wrap"
        style="max-width: {{ section.settings.media_max_width }}px;"
      >
        <iframe
          src="https://www.youtube.com/embed/{{ section.settings.youtube_id }}?rel=0&modestbranding=1"
          title="{{ section.settings.heading | escape }}"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
    {%- elsif section.settings.video_url != blank -%}
      <!-- Native video -->
      <div
        class="al-video-wrap"
        style="max-width: {{ section.settings.media_max_width }}px;"
      >
        {%- if section.settings.poster_image != blank -%}
          {%- assign poster_url = section.settings.poster_image | image_url: width: 1200 -%}
        {%- else -%}
          {%- assign poster_url = '' -%}
        {%- endif -%}
        <video
          src="{{ section.settings.video_url }}"
          {% if poster_url != '' %}poster="{{ poster_url }}"{% endif %}
          {% if section.settings.autoplay %}autoplay muted playsinline loop{% endif %}
          controls
          preload="metadata"
          style="width:100%;height:auto;display:block;background:#000;"
        >
          Your browser does not support the video tag.
        </video>
      </div>
    {%- endif -%}

    {%- if section.settings.cta_label != blank or section.settings.ghost_label != blank -%}
      <div style="display:flex;gap:16px;justify-content:{{ section.settings.text_align }};flex-wrap:wrap;margin-top:40px;">
        {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}
          <a
            href="{{ section.settings.cta_link }}"
            class="button button--primary al-btn-glow"
            style="font-size:1rem;padding:14px 32px;"
          >
            {{ section.settings.cta_label }} &rarr;
          </a>
        {%- endif -%}
        {%- if section.settings.ghost_label != blank and section.settings.ghost_link != blank -%}
          <a
            href="{{ section.settings.ghost_link }}"
            class="button button--secondary"
            style="font-size:1rem;padding:14px 32px;"
          >
            {{ section.settings.ghost_label }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "AL \u2014 Video Section",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Layout" },
    { "type": "select", "id": "background_style", "label": "Background",
      "options": [
        { "value": "dark", "label": "Dark (default)" },
        { "value": "surface", "label": "Surface" }
      ],
      "default": "surface"
    },
    { "type": "range", "id": "padding_top",    "label": "Padding top",    "min": 0, "max": 120, "step": 4, "default": 80, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 120, "step": 4, "default": 80, "unit": "px" },
    { "type": "range", "id": "max_width",      "label": "Content max width", "min": 600, "max": 1400, "step": 20, "default": 1200, "unit": "px" },
    { "type": "range", "id": "media_max_width","label": "Video max width",  "min": 400, "max": 1200, "step": 20, "default": 960,  "unit": "px" },
    { "type": "select", "id": "text_align", "label": "Text alignment",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ],
      "default": "center"
    },
    { "type": "header", "content": "Content" },
    { "type": "text",          "id": "eyebrow",     "label": "Eyebrow label",  "default": "See It In Action" },
    { "type": "inline_richtext","id": "heading",    "label": "Heading",        "default": "Watch How It Works" },
    { "type": "select",        "id": "heading_tag", "label": "Heading tag",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ],
      "default": "h2"
    },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "" },
    { "type": "header", "content": "Video" },
    { "type": "text",         "id": "youtube_id",  "label": "YouTube Video ID",      "info": "From youtube.com/watch?v=XXXXXXXXXXX" },
    { "type": "text",         "id": "video_url",   "label": "CDN Video URL (.mp4/.mov)", "info": "Paste Shopify CDN video URL" },
    { "type": "image_picker", "id": "poster_image","label": "Video poster image",     "info": "Shown before video plays" },
    { "type": "checkbox",     "id": "autoplay",    "label": "Autoplay (muted)",       "default": true },
    { "type": "header", "content": "Buttons" },
    { "type": "text", "id": "cta_label",   "label": "Primary button label" },
    { "type": "url",  "id": "cta_link",    "label": "Primary button link" },
    { "type": "text", "id": "ghost_label", "label": "Secondary button label" },
    { "type": "url",  "id": "ghost_link",  "label": "Secondary button link" }
  ],
  "presets": [
    {
      "name": "AL \u2014 Video Section",
      "settings": {
        "eyebrow": "See It In Action",
        "heading": "Watch How It Works",
        "subheading": "From box to wireless CarPlay in 60 seconds.",
        "video_url": "https://cdn.shopify.com/videos/c/o/v/f710c015c61142c997c93fa5dd13c01d.mov",
        "autoplay": true
      }
    }
  ]
}
{% endschema %}