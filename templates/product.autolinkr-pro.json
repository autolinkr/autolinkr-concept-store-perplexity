    "multicolumn-features": {
      "type": "multicolumn-with-icons",
      "blocks": {
        "col-1": {
          "type": "column",
          "settings": {
            "icon": "bolt",
            "heading": "Instant Wireless Freedom",
            "text": "<p>Pair once — every drive connects automatically in seconds. No more fumbling with cables, no more USB ports taken over.</p>"
          }
        },
        "col-2": {
          "type": "column",
          "settings": {
            "icon": "play-button",
            "heading": "Netflix & YouTube On Screen",
            "text": "<p>Stream full HD video directly on your factory display. Google Play Store unlocks every app your phone can run.</p>"
          }
        },
        "col-3": {
          "type": "column",
          "settings": {
            "icon": "wifi",
            "heading": "5GHz — Zero Lag",
            "text": "<p>Dual-band 5GHz Wi-Fi delivers the speed to keep navigation, music, and streaming running flawlessly on every drive.</p>"
          }
        },
        "col-4": {
          "type": "column",
          "settings": {
            "icon": "shield",
            "heading": "Works With Your Car",
            "text": "<p>Compatible with 97%+ of vehicles that have factory wired CarPlay. No modifications needed — just plug in and pair once.</p>"
          }
        }
      },
      "block_order": ["col-1", "col-2", "col-3", "col-4"],
      "settings": {
        "style": "with-border",
        "columns": 4,
        "text_alignment": "left",
        "heading": "Why 50,000+ Drivers Choose AutoLinkr Pro™",
        "heading_size": "title-md",
        "heading_alignment": "text-center md:items-center",
        "heading_tag": "h2"
