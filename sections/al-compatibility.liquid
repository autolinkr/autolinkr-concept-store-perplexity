{% comment %}
  AutoLinkr — Compatibility Section
  High-impact, objection-crushing section. Answers the #1 hesitation: "Will it work with my car?"
{% endcomment %}

<section class="al-compat" style="
  padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  background: rgb(var(--color-base-background));
">
  <div class="page-width al-compat__inner">

    {%- comment -%} Left — image {%- endcomment -%}
    <div class="al-compat__img-wrap">
      {%- if section.settings.image != blank -%}
        <img
          src="{{ section.settings.image | image_url: width: 900 }}"
          alt="AutoLinkr works with your car"
          loading="lazy"
          width="900"
          style="width:100%;height:100%;object-fit:cover;display:block;"
        >
      {%- endif -%}
      {%- comment -%} Stat badge overlaid on image {%- endcomment -%}
      <div class="al-compat__badge">
        <span class="al-compat__badge-num">500+</span>
        <span class="al-compat__badge-label">Compatible Models</span>
      </div>
    </div>

    {%- comment -%} Right — content {%- endcomment -%}
    <div class="al-compat__content">

      <span class="al-compat__eyebrow">Compatibility</span>

      <h2 class="al-compat__heading">
        Works With<br>
        <em>Your</em> Car.
      </h2>

      <p class="al-compat__lead">
        Any vehicle with <strong>factory CarPlay or Android Auto</strong> — or an <strong>aftermarket head unit</strong> with CarPlay built in. That's 500+ models across 30+ brands.
      </p>

      <div class="al-compat__brands">
        Toyota · Honda · Ford · Chevrolet · BMW · Mercedes · Hyundai · Kia · Nissan · Subaru · Mazda · Audi · Lexus · Jeep · <span style="color:rgba(59,142,248,0.8);">30+ more</span>
      </div>

      <div class="al-compat__aftermarket">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="7" cy="7" r="6" stroke="rgba(59,142,248,0.7)" stroke-width="1.5"/>
          <path d="M4.5 7L6.5 9L9.5 5" stroke="rgba(59,142,248,0.9)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Alpine, Pioneer &amp; Kenwood head units with CarPlay? You're covered.
      </div>

      <div class="al-compat__guarantee">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M9 1L11.09 6.26L17 7.27L13 11.14L14.18 17L9 14.27L3.82 17L5 11.14L1 7.27L6.91 6.26L9 1Z" fill="rgba(59,142,248,0.9)" stroke="rgba(59,142,248,0.9)" stroke-width="1" stroke-linejoin="round"/>
        </svg>
        If it doesn't work — <strong>full refund, no questions.</strong>
      </div>

      <a href="{{ section.settings.button_link | default: '/pages/supported-cars' }}" class="al-compat__btn">
        {{ section.settings.button_label | default: 'Check Your Car →' }}
      </a>

      <p class="al-compat__sub">Not sure? <a href="mailto:support@theautolinkr.com">Email us</a> — we confirm in minutes.</p>

    </div>

  </div>
</section>

<style>
  .al-compat__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    align-items: stretch;
    border: 2px solid rgba(59,142,248,0.45);
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 0 48px rgba(59,142,248,0.08), 0 24px 64px rgba(0,0,0,0.5);
  }

  /* Image pane */
  .al-compat__img-wrap {
    position: relative;
    min-height: 480px;
    overflow: hidden;
    background: var(--al-surface-2);
  }

  .al-compat__img-wrap img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Stat badge on image */
  .al-compat__badge {
    position: absolute;
    bottom: 28px;
    left: 28px;
    background: rgba(8,8,9,0.75);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(59,142,248,0.35);
    border-radius: 14px;
    padding: 14px 20px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .al-compat__badge-num {
    font-family: var(--al-font-display,'General Sans',sans-serif);
    font-size: 2rem;
    font-weight: 800;
    color: #fff;
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .al-compat__badge-label {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(59,142,248,0.9);
  }

  /* Content pane */
  .al-compat__content {
    padding: 56px 52px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: var(--al-surface);
    border-left: 1px solid rgba(59,142,248,0.2);
  }

  .al-compat__eyebrow {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(59,142,248,0.85);
    margin-bottom: 16px;
    display: block;
  }

  .al-compat__heading {
    font-family: var(--al-font-display,'General Sans',sans-serif);
    font-size: clamp(2.25rem, 4vw, 3.25rem);
    font-weight: 800;
    color: #fff;
    line-height: 1.0;
    letter-spacing: -0.04em;
    margin: 0 0 24px;
  }

  .al-compat__heading em {
    font-style: italic;
    color: rgba(59,142,248,1);
  }

  .al-compat__lead {
    font-size: 1.0625rem;
    line-height: 1.65;
    color: rgba(255,255,255,0.7);
    margin: 0 0 20px;
  }

  .al-compat__lead strong { color: #fff; }

  .al-compat__brands {
    font-size: 0.875rem;
    line-height: 1.8;
    color: rgba(255,255,255,0.45);
    margin: 0 0 12px;
    font-family: var(--al-font-body,'Inter',sans-serif);
  }

  .al-compat__aftermarket {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.8125rem;
    color: rgba(255,255,255,0.5);
    margin: 0 0 28px;
    font-family: var(--al-font-body,'Inter',sans-serif);
  }

  .al-compat__guarantee {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.9375rem;
    color: rgba(255,255,255,0.6);
    margin-bottom: 32px;
    padding: 14px 18px;
    background: rgba(59,142,248,0.07);
    border: 1px solid rgba(59,142,248,0.2);
    border-radius: 10px;
  }

  .al-compat__guarantee strong { color: #fff; }

  /* CTA button */
  .al-compat__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(59,142,248,1);
    color: #fff;
    font-family: var(--al-font-display,'General Sans',sans-serif);
    font-weight: 700;
    font-size: 1.0625rem;
    padding: 16px 36px;
    border-radius: 100px;
    text-decoration: none;
    transition: background 0.2s ease, box-shadow 0.2s ease, transform 0.15s ease;
    box-shadow: 0 0 24px rgba(59,142,248,0.35);
    align-self: flex-start;
    margin-bottom: 16px;
  }

  .al-compat__btn:hover {
    background: rgba(36,120,232,1);
    box-shadow: 0 0 40px rgba(59,142,248,0.5);
    transform: translateY(-1px);
  }

  .al-compat__sub {
    font-size: 0.8125rem;
    color: rgba(255,255,255,0.35);
    margin: 0;
  }

  .al-compat__sub a {
    color: rgba(59,142,248,0.8);
    text-decoration: none;
  }

  .al-compat__sub a:hover { text-decoration: underline; }

  /* Mobile */
  @media (max-width: 768px) {
    .al-compat__inner {
      grid-template-columns: 1fr;
      border-radius: 16px;
    }

    .al-compat__img-wrap {
      min-height: 260px;
      border-left: none;
      border-bottom: 1px solid rgba(59,142,248,0.2);
    }

    .al-compat__content {
      padding: 36px 28px;
      border-left: none;
    }

    .al-compat__heading { font-size: 2.25rem; }
    .al-compat__btn { width: 100%; text-align: center; }
  }
</style>

{% schema %}
{
  "name": "AL — Compatibility",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Check Your Car →" },
    { "type": "url",  "id": "button_link",  "label": "Button link" },
    { "type": "range", "id": "padding_top",    "label": "Padding top",    "min": 20, "max": 120, "step": 4, "default": 72, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 20, "max": 120, "step": 4, "default": 72, "unit": "px" }
  ],
  "presets": [{ "name": "AL — Compatibility" }],
  "disabled_on": { "groups": ["footer","header","custom.overlay"] }
}
{% endschema %}
