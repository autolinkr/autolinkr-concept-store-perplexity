{% comment %}
  autolinkr-collection-hero.liquid
  AutoLinkr Collection Page Hero Banner
  Phase C — ConceptThemePerplexity

  Renders:
  - Collection-specific hero headline + sub
  - Product count / trust signal
  - Pro → Elite upgrade nudge (Adapters collection only)
  - Breadcrumb
{% endcomment %}

{{ 'autolinkr-collection.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign is_adapters = false
  assign is_dash_cams = false
  if collection.handle == 'adapters' or collection.handle == 'carplay-adapters' or collection.handle == 'wireless-carplay'
    assign is_adapters = true
  endif
  if collection.handle == 'dash-cams' or collection.handle == 'dashcams'
    assign is_dash_cams = true
  endif
  assign col_title = section.settings.hero_title | default: collection.title
  assign col_sub   = section.settings.hero_sub   | default: collection.description
-%}

<section
  class="al-col-hero"
  data-section-id="{{ section.id }}"
  data-section-type="autolinkr-collection-hero"
  data-collection="{{ collection.handle }}"
>
  {%- comment %} Ambient glow {%- endcomment %}
  <div class="al-col-hero__bg" aria-hidden="true">
    <div class="al-col-hero__bg-glow{% if is_dash_cams %} al-col-hero__bg-glow--green{% else %} al-col-hero__bg-glow--blue{% endif %}"></div>
  </div>

  <div class="al-container al-col-hero__inner">

    {%- comment %} Breadcrumb {%- endcomment %}
    <nav class="al-col-hero__breadcrumb" aria-label="Breadcrumb">
      <a href="/" class="al-col-hero__breadcrumb-link">Home</a>
      <span class="al-col-hero__breadcrumb-sep" aria-hidden="true">/</span>
      <span class="al-col-hero__breadcrumb-current">{{ col_title }}</span>
    </nav>

    {%- comment %} Eyebrow {%- endcomment %}
    <div class="al-col-hero__eyebrow">
      {%- if is_adapters -%}
        <span class="al-badge al-badge--blue">Wireless CarPlay Adapters</span>
      {%- elsif is_dash_cams -%}
        <span class="al-badge al-badge--green">Dual 1080P Dashcams</span>
      {%- else -%}
        <span class="al-badge al-badge--blue">{{ col_title }}</span>
      {%- endif -%}
      <span class="al-col-hero__count">{{ collection.products_count }} products</span>
    </div>

    {%- comment %} Headline {%- endcomment %}
    <h1 class="al-col-hero__title">
      {%- if section.settings.hero_title != blank -%}
        {{ section.settings.hero_title }}
      {%- elsif is_adapters -%}
        Upgrade to Wireless CarPlay
      {%- elsif is_dash_cams -%}
        Dual-Camera Dashcams
      {%- else -%}
        {{ collection.title }}
      {%- endif -%}
    </h1>

    {%- comment %} Sub {%- endcomment %}
    <p class="al-col-hero__sub">
      {%- if section.settings.hero_sub != blank -%}
        {{ section.settings.hero_sub }}
      {%- elsif is_adapters -%}
        From wireless CarPlay to streaming Netflix and Google Play — find the right AutoLinkr for your car and your needs.
      {%- elsif is_dash_cams -%}
        Front and interior cabin recording in 1080P. IR night vision. G-sensor protection. Built for drivers who want proof.
      {%- else -%}
        {{ collection.description | strip_html | truncate: 160 }}
      {%- endif -%}
    </p>

    {%- comment %} Pro → Elite nudge (Adapters collection only) {%- endcomment %}
    {%- if is_adapters -%}
    <div class="al-col-hero__upgrade-nudge">
      <div class="al-col-hero__upgrade-nudge-inner">
        <div class="al-col-hero__upgrade-nudge-steps">
          <span class="al-col-hero__upgrade-step al-col-hero__upgrade-step--base">
            Base™ <span class="al-col-hero__upgrade-price">$69.99</span>
            <span class="al-col-hero__upgrade-label">Wireless only</span>
          </span>
          <svg class="al-col-hero__upgrade-arrow" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M4 10h12M12 6l4 4-4 4" stroke="#A1A1A6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="al-col-hero__upgrade-step al-col-hero__upgrade-step--pro">
            Pro™ <span class="al-col-hero__upgrade-price">$79.99</span>
            <span class="al-col-hero__upgrade-label">+ Streaming apps</span>
          </span>
          <svg class="al-col-hero__upgrade-arrow" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M4 10h12M12 6l4 4-4 4" stroke="#FF9500" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="al-col-hero__upgrade-step al-col-hero__upgrade-step--elite">
            Elite™ <span class="al-col-hero__upgrade-price">$199.99</span>
            <span class="al-col-hero__upgrade-label">+ Split-screen</span>
          </span>
        </div>
        <p class="al-col-hero__upgrade-hint">
          <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true"><circle cx="6.5" cy="6.5" r="5" stroke="#A1A1A6" stroke-width="1.25"/><path d="M6.5 5.5v3M6.5 4.5v.25" stroke="#A1A1A6" stroke-width="1.25" stroke-linecap="round"/></svg>
          All adapters require existing factory CarPlay or Android Auto
        </p>
      </div>
    </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "AL Collection Hero",
  "tag": "section",
  "class": "al-col-hero-section",
  "settings": [
    {
      "type": "text",
      "id": "hero_title",
      "label": "Hero Title (overrides collection title)"
    },
    {
      "type": "textarea",
      "id": "hero_sub",
      "label": "Hero Sub (overrides collection description)"
    }
  ],
  "presets": [
    {
      "name": "AL Collection Hero"
    }
  ]
}
{% endschema %}
