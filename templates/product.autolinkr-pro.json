        "text-tagline": {
          "type": "text",
          "settings": {
            "text": "Converts wired CarPlay to wireless — plus unlocks Netflix, YouTube & Google Play on your factory screen. Plug in. Pair once. Drive.",
            "text_size": "text-base",
            "icon": "none"
          }
        },
        "variant_picker": {
          "type": "variant_picker",
          "settings": {
            "enable_dynamic_variants": true,
            "show_variant_labels": true,
            "picker_type": "button",
            "enable_color_swatches": false
          }
