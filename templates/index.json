    "multicolumn-why": {
      "type": "multicolumn-with-icons",
      "blocks": {
        "col-1": {
          "type": "column",
          "settings": {
            "icon": "wifi",
            "heading": "Truly Wireless CarPlay",
            "text": "<p>Cut the cord for good. AutoLinkr converts your existing factory wired CarPlay into a wireless connection \u2014 pair once, auto-connect forever.</p>"
          }
        },
        "col-2": {
          "type": "column",
          "settings": {
            "icon": "play-button",
            "heading": "Netflix, YouTube & More",
            "text": "<p>Stream full HD on your car's own display. The Google Play Store unlocks every app your phone already runs \u2014 no sideloading, no hacks.</p>"
          }
        },
        "col-3": {
          "type": "column",
          "settings": {
            "icon": "bolt",
            "heading": "Works With Your Car",
            "text": "<p>Compatible with 97%+ of vehicles with factory wired CarPlay. BMW, Mercedes, Toyota, Ford, Honda, and 100+ other makes. No modifications needed.</p>"
          }
        },
        "col-4": {
          "type": "column",
          "settings": {
            "icon": "shield",
            "heading": "Zero Risk Purchase",
            "text": "<p>30-day money-back guarantee. 1-year warranty. Free shipping. You're covered from the day you order to a full year after.</p>"
          }
        }
      },
