        "title": {
          "type": "title",
          "settings": {
            "title_size": "product-title-lg",
            "title_size_mobile": "product-title-md",
            "title_tag": "h1",
            "show_price": true,
            "show_rating": true
          }
        },
        "text-tagline": {
          "type": "text",
          "settings": {
            "text": "Dual 1080P front + rear recording with IR night vision, 170° wide-angle lens, and WiFi app control. Always-on protection, loop recording, and G-sensor collision detection.",
