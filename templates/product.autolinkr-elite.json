    "multicolumn-features": {
      "type": "multicolumn-with-icons",
      "blocks": {
        "col-1": {
          "type": "column",
          "settings": {
            "icon": "bolt",
            "heading": "Split-Screen Multitasking",
            "text": "<p>Run two apps simultaneously — GPS + Netflix, YouTube + Spotify. This is the feature that sets Elite apart from everything else on the market.</p>"
          }
        },
        "col-2": {
          "type": "column",
          "settings": {
            "icon": "processor",
            "heading": "Faster CPU Processor",
            "text": "<p>Elite's upgraded chip delivers faster app load times, smoother video playback, and zero buffering — even when running two apps at once.</p>"
          }
        },
        "col-3": {
          "type": "column",
          "settings": {
            "icon": "play-button",
            "heading": "Full Streaming Suite",
            "text": "<p>Netflix, YouTube, Google Play Store — stream anything. The Google Play Store lets you install virtually any Android app on your screen.</p>"
          }
        },
        "col-4": {
          "type": "column",
          "settings": {
            "icon": "wifi",
            "heading": "Seamless Wireless CarPlay",
            "text": "<p>Pair once, connect every time. Your iPhone connects automatically the moment you start the car — no cables, no delays.</p>"
          }
        }
      },
      "block_order": [
        "col-1",
        "col-2",
        "col-3",
        "col-4"
      ],
