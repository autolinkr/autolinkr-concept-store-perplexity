{% comment %}
  AutoLinkr — How It Works (3-step with real images)
  Dark premium alternating layout: text left/img right, then flip
  Uses real CDN image URLs embedded via custom-liquid or section settings
{% endcomment %}

<section class="al-hiw" style="
  background: #0A0A0C;
  padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
">
  <div class="page-width" style="max-width:1200px;margin:0 auto;padding:0 24px;">

    {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
      <div class="al-hiw__header" style="text-align:center;margin-bottom:64px;">
        {%- if section.settings.eyebrow != blank -%}
          <span class="al-label">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 style="font-family:var(--al-font-display,'General Sans',sans-serif);font-size:clamp(1.875rem,3.5vw,2.75rem);font-weight:700;color:#F5F5F7;letter-spacing:-0.025em;line-height:1.1;margin:0 auto 16px;max-width:640px;">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p style="color:#ABABB3;font-size:1.0625rem;line-height:1.65;max-width:520px;margin:0 auto;">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="al-hiw__steps">
      {%- for block in section.blocks -%}
        {%- if block.type == 'step' -%}
          {%- assign step_num = forloop.index -%}
          {%- assign is_even = forloop.index | modulo: 2 -%}
          <div class="al-step{% if is_even == 0 %} al-step--reverse{% endif %}" {{ block.shopify_attributes }}>

            <div class="al-step__text">
              <div class="al-step__num">{{ step_num }}</div>
              <h3 class="al-step__heading">{{ block.settings.heading }}</h3>
              <p class="al-step__body">{{ block.settings.body }}</p>
              {%- if block.settings.badge != blank -%}
                <span class="al-label" style="margin-top:12px;">{{ block.settings.badge }}</span>
              {%- endif -%}
            </div>

            <div class="al-step__img">
              {%- if block.settings.image_url != blank -%}
                <img
                  src="{{ block.settings.image_url }}"
                  alt="{{ block.settings.heading | escape }}"
                  loading="lazy"
                  style="width:100%;height:auto;display:block;object-fit:cover;aspect-ratio:{{ block.settings.image_ratio }};"
                >
              {%- elsif block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | image_url: width: 800 }}"
                  alt="{{ block.settings.heading | escape }}"
                  loading="lazy"
                  style="width:100%;height:auto;display:block;"
                >
              {%- else -%}
                <div style="aspect-ratio:4/3;background:#121215;display:flex;align-items:center;justify-content:center;color:#404046;font-size:0.875rem;font-family:var(--al-font-display);">Add image in theme editor</div>
              {%- endif -%}
            </div>

          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}
      <div style="text-align:center;margin-top:56px;">
        <a href="{{ section.settings.cta_link }}" class="button button--primary al-btn-glow" style="font-size:1rem;padding:14px 32px;">
          {{ section.settings.cta_label }} →
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

<style>
  .al-hiw__steps { display: flex; flex-direction: column; gap: 0; }

  .al-step {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
    padding: 64px 0;
    border-bottom: 1px solid #1E1E23;
  }

  .al-step:last-child { border-bottom: none; }

  .al-step--reverse { direction: rtl; }
  .al-step--reverse > * { direction: ltr; }

  .al-step__text { padding: 8px 0; }

  .al-step__img {
    border-radius: 16px;
    overflow: hidden;
    background: #121215;
    border: 1px solid #2C2C32;
    box-shadow: 0 20px 60px rgba(0,0,0,0.5);
  }

  @media (max-width: 768px) {
    .al-step { grid-template-columns: 1fr; gap: 28px; direction: ltr; padding: 40px 0; }
    .al-step--reverse { direction: ltr; }
    .al-step__img { order: -1; }
  }
</style>

{% schema %}
{
  "name": "AL — How It Works",
  "tag": "section",
  "settings": [
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 20, "max": 120, "step": 4, "default": 80, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 20, "max": 120, "step": 4, "default": 80, "unit": "px" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Setup Guide" },
    { "type": "inline_richtext", "id": "heading", "label": "Section heading", "default": "Up and Running in 60 Seconds" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "No tools. No apps. No installation knowledge required." },
    { "type": "text", "id": "cta_label", "label": "CTA button label" },
    { "type": "url", "id": "cta_link", "label": "CTA button link" }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "inline_richtext", "id": "heading", "label": "Step heading", "default": "Plug In the Adapter" },
        { "type": "textarea", "id": "body", "label": "Step description", "default": "Connect the AutoLinkr adapter to your car's factory CarPlay USB port using the included cable. The adapter powers on automatically." },
        { "type": "text", "id": "badge", "label": "Badge label (optional)", "info": "e.g. '60 sec' or 'One time only'" },
        { "type": "text", "id": "image_url", "label": "Image CDN URL", "info": "Paste Shopify CDN URL directly (recommended)" },
        { "type": "image_picker", "id": "image", "label": "Or pick image from theme assets" },
        { "type": "select", "id": "image_ratio", "label": "Image aspect ratio", "options": [
            {"value": "4/3", "label": "4:3"},
            {"value": "16/9", "label": "16:9"},
            {"value": "1/1", "label": "Square"},
            {"value": "3/2", "label": "3:2"}
          ], "default": "4/3" }
      ]
    }
  ],
  "presets": [
    {
      "name": "AL — How It Works",
      "settings": {
        "eyebrow": "Setup Guide",
        "heading": "Up and Running in 60 Seconds",
        "subheading": "No tools. No apps. No installation knowledge required.",
        "cta_label": "Shop AutoLinkr Pro™",
        "cta_link": "/products/the-autolinkr-pro"
      },
      "blocks": [
        {
          "type": "step",
          "settings": {
            "heading": "Step 1 — Plug In",
            "body": "Connect AutoLinkr to your car's factory CarPlay USB port using the included cable. The adapter powers on automatically when the car starts.",
            "badge": "30 seconds",
            "image_url": "https://cdn.shopify.com/s/files/1/0706/8971/8306/files/Adapter17.png?v=1704950035",
            "image_ratio": "4/3"
          }
        },
        {
          "type": "step",
          "settings": {
            "heading": "Step 2 — Pair Once",
            "body": "Connect your iPhone to Bluetooth 'HI-BOX:' and join the Wi-Fi hotspot shown on your screen. This one-time setup takes about 30 seconds.",
            "badge": "One time only",
            "image_url": "https://cdn.shopify.com/s/files/1/0706/8971/8306/files/Wifi_Passcode_Image.webp?v=1718322092",
            "image_ratio": "4/3"
          }
        },
        {
          "type": "step",
          "settings": {
            "heading": "Step 3 — Auto-Connect Forever",
            "body": "Every future drive connects automatically the moment you start your car. No more cables. No more steps. Just wireless CarPlay and streaming, every drive.",
            "badge": "Every drive, automatic",
            "image_url": "https://cdn.shopify.com/s/files/1/0706/8971/8306/files/WCPAA-Dual_cover-02.webp?v=1718169515",
            "image_ratio": "4/3"
          }
        }
      ]
    }
  ]
}
{% endschema %}
