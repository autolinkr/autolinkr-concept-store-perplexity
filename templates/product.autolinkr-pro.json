        "text-trust-3": {
          "type": "text",
          "settings": {
            "text": "✓ 1-Year Warranty Included",
            "text_size": "text-sm",
            "icon": "none"
          }
        },
        "collapsible-whats-included": {
          "type": "collapsible_tab",
          "settings": {
            "opened": true,
            "style": "with-border",
            "icon": "none",
            "heading": "What's Included",
            "content": "<ul><li>AutoLinkr Pro™ Adapter</li><li>USB-A to USB-C Cable</li><li>Quick-Start Guide</li></ul>",
            "text_size": "text-sm"
          }
        },
        "collapsible-works-with": {
          "type": "collapsible_tab",
          "settings": {
            "opened": false,
            "style": "with-border",
            "icon": "none",
            "heading": "Works With",
            "content": "<p><strong>Requirements:</strong> Vehicle must have factory-installed wired CarPlay. AutoLinkr Pro™ does NOT add CarPlay to vehicles that don't already have it.</p><p><strong>Compatible iPhones:</strong> iPhone 7 and newer running iOS 10+</p><p><strong>Compatible Vehicles:</strong> Any car with factory wired CarPlay (2016+). Works with BMW, Mercedes, Honda, Toyota, Ford, Chevy, Audi, VW, and 100+ other makes.</p>",
            "text_size": "text-sm"
          }
        },
        "collapsible-streaming": {
          "type": "collapsible_tab",
          "settings": {
            "opened": false,
            "style": "with-border",
            "icon": "none",
            "heading": "Streaming Apps Unlocked",
            "content": "<p>AutoLinkr Pro™ unlocks full streaming and app access on your factory CarPlay screen:</p><ul><li>Netflix</li><li>YouTube</li><li>Google Play Store (download any app)</li><li>Hulu, Disney+, Amazon Prime Video</li><li>Spotify, Apple Music, Pandora</li><li>Waze, Google Maps</li></ul><p><em>Streaming apps require a data connection. Use responsibly — only stream when parked or with a passenger.</em></p>",
            "text_size": "text-sm"
          }
        },
        "description": {
          "type": "description",
          "settings": {
            "text_size": "text-sm"
          }
        },
        "rating": {
          "type": "rating",
          "settings": {}
        }
