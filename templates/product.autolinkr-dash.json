        "collapsible-whats-included": {
          "type": "collapsible_tab",
          "settings": {
            "opened": true,
            "style": "with-border",
            "icon": "none",
            "heading": "What's Included",
            "content": "<ul><li>AutoLinkr Dash™ Front Camera</li><li>Rear Camera (with cable)</li><li>Adhesive Mount</li><li>Power Cable (12V car adapter)</li><li>SD Card (if selected variant)</li><li>Quick-Start Guide</li></ul>",
            "text_size": "text-sm"
          }
        },
        "collapsible-specs": {
          "type": "collapsible_tab",
          "settings": {
            "opened": false,
            "style": "with-border",
            "icon": "none",
            "heading": "Full Specifications",
            "content": "<ul><li><strong>Resolution:</strong> Dual 1080P Full HD (front + rear)</li><li><strong>Field of View:</strong> 170° ultra-wide front, 140° rear</li><li><strong>Night Vision:</strong> IR infrared night vision (clear footage in darkness)</li><li><strong>Loop Recording:</strong> Automatic — old footage overwritten when card is full</li><li><strong>G-Sensor:</strong> Auto-locks footage on collision or hard braking</li><li><strong>Connectivity:</strong> WiFi app control (iOS + Android)</li><li><strong>Parking Mode:</strong> Motion detection while parked</li><li><strong>Power:</strong> 12V car power adapter (included)</li><li><strong>Storage:</strong> microSD (Class 10 or above) — No SD, 32GB, or 64GB options</li><li><strong>Operating Temp:</strong> -20°C to 70°C</li></ul>",
            "text_size": "text-sm"
          }
        },
        "collapsible-installation": {
          "type": "collapsible_tab",
          "settings": {
            "opened": false,
            "style": "with-border",
            "icon": "none",
            "heading": "Installation Guide",
            "content": "<ol><li>Attach front camera to windshield with adhesive mount (top center, behind rearview mirror).</li><li>Route rear camera cable along the headliner to the back window.</li><li>Connect power cable to 12V outlet (cigarette lighter).</li><li>Format SD card using the camera menu before first use.</li><li>Download the AutoLinkr WiFi app to view live footage and adjust settings.</li></ol><p><em>No professional installation required. Average setup time: 20-30 minutes.</em></p>",
            "text_size": "text-sm"
          }
        },
        "description": {
          "type": "description",
          "settings": {
            "text_size": "text-sm"
          }
        },
