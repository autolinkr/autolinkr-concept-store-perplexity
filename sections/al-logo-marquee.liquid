<style>
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    {%- render 'section-variables', section: section -%}
  }

  /* ── Marquee wrapper ── */
  #shopify-section-{{ section.id }} .al-marquee-outer {
    position: relative;
    overflow: hidden;
    width: 100%;
  }

  /* Fade edges */
  #shopify-section-{{ section.id }} .al-marquee-outer::before,
  #shopify-section-{{ section.id }} .al-marquee-outer::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 120px;
    z-index: 2;
    pointer-events: none;
  }
  #shopify-section-{{ section.id }} .al-marquee-outer::before {
    left: 0;
    background: linear-gradient(to right, rgb(var(--color-base-background)) 0%, transparent 100%);
  }
  #shopify-section-{{ section.id }} .al-marquee-outer::after {
    right: 0;
    background: linear-gradient(to left, rgb(var(--color-base-background)) 0%, transparent 100%);
  }

  /* The scrolling track — duplicated for seamless loop */
  #shopify-section-{{ section.id }} .al-marquee-track {
    display: flex;
    align-items: center;
    gap: {{ section.settings.gap }}px;
    width: max-content;
    animation: al-marquee-scroll {{ section.settings.speed }}s linear infinite;
  }

  #shopify-section-{{ section.id }} .al-marquee-track:hover {
    animation-play-state: paused;
  }

  /* Each logo item */
  #shopify-section-{{ section.id }} .al-marquee-item {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    opacity: 0.5;
    transition: opacity 0.25s ease;
    padding: 0 {{ section.settings.gap | divided_by: 2 }}px;
  }

  #shopify-section-{{ section.id }} .al-marquee-item:hover {
    opacity: 1;
  }

  #shopify-section-{{ section.id }} .al-marquee-item img {
    height: {{ section.settings.logo_height }}px;
    width: auto;
    display: block;
    filter: brightness(0) invert(1);
    object-fit: contain;
  }

  /* Separator dot between logos */
  #shopify-section-{{ section.id }} .al-marquee-sep {
    flex-shrink: 0;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: rgba(59, 142, 248, 0.4);
  }

  @keyframes al-marquee-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* Eyebrow label */
  #shopify-section-{{ section.id }} .al-marquee-eyebrow {
    text-align: center;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    margin-bottom: 28px;
    font-family: var(--al-font-body, 'Inter', sans-serif);
  }
</style>

<div class="section section--padding{% if section.settings.divider %} section--divider{% endif %}">
  <div class="page-width">

    {%- if section.settings.eyebrow != blank -%}
      <p class="al-marquee-eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="al-marquee-outer">
        {%- comment -%} Track is rendered twice for seamless infinite loop {%- endcomment -%}
        <div class="al-marquee-track" aria-hidden="false">

          {%- comment -%} First copy {%- endcomment -%}
          {%- for block in section.blocks -%}
            {%- if block.settings.image != blank -%}
              <div class="al-marquee-item" {{ block.shopify_attributes }}>
                {%- assign image_width = section.settings.logo_height | times: block.settings.image.aspect_ratio | round -%}
                {{- block.settings.image | image_url: width: 400 | image_tag:
                    loading: 'lazy',
                    widths: '100, 200, 400',
                    sizes: '200px' -}}
                {%- if block.settings.link != blank -%}
                  <a href="{{ block.settings.link }}" class="block absolute inset-0" aria-label="{{ block.settings.image.alt | default: 'Press logo' }}">&nbsp;</a>
                {%- endif -%}
              </div>
              {%- unless forloop.last -%}
                <div class="al-marquee-sep" aria-hidden="true"></div>
              {%- endunless -%}
            {%- endif -%}
          {%- endfor -%}

          {%- comment -%} Duplicate copy for seamless loop {%- endcomment -%}
          {%- for block in section.blocks -%}
            {%- if block.settings.image != blank -%}
              <div class="al-marquee-item" aria-hidden="true">
                {{- block.settings.image | image_url: width: 400 | image_tag:
                    loading: 'lazy',
                    widths: '100, 200, 400',
                    sizes: '200px' -}}
              </div>
              {%- unless forloop.last -%}
                <div class="al-marquee-sep" aria-hidden="true"></div>
              {%- endunless -%}
            {%- endif -%}
          {%- endfor -%}

        </div>
      </div>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "AL — Logo Marquee",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "As Featured In"
    },
    {
      "type": "range",
      "id": "logo_height",
      "label": "Logo height (px)",
      "min": 24,
      "max": 120,
      "step": 4,
      "default": 100,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between logos (px)",
      "min": 24,
      "max": 120,
      "step": 8,
      "default": 64,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll speed (seconds per loop)",
      "min": 10,
      "max": 60,
      "step": 2,
      "default": 24,
      "unit": "s",
      "info": "Lower = faster. Pauses on hover."
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "checkbox",
      "id": "divider",
      "label": "Show divider",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "AL — Logo Marquee",
      "settings": {
        "eyebrow": "As Featured In",
        "logo_height": 100,
        "gap": 64,
        "speed": 24
      }
    }
  ],
  "disabled_on": {
    "groups": ["footer", "header", "custom.overlay"]
  }
}
{% endschema %}
