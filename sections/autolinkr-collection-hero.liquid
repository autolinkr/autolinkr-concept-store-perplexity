{% comment %}
  autolinkr-collection-hero.liquid
  AutoLinkr Collection Page — Hero + Product Grid
  Phase C — ConceptThemePerplexity

  Renders:
  - Collection headline + subhead
  - Product grid (2-up mobile, 3-up desktop)
  - Each card: image, title, price, quick-add
{% endcomment %}

{{ 'autolinkr-collection.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign col = collection
  assign sort_by = collection.sort_by | default: collection.default_sort_by
-%}

<section
  class="al-col-hero"
  data-section-id="{{ section.id }}"
  data-section-type="autolinkr-collection-hero"
>
  <div class="al-container">

    {%- comment %} ── HEADER ── {%- endcomment %}
    <header class="al-col-hero__header">
      <h1 class="al-col-hero__title">{{ col.title }}</h1>
      {%- if col.description != blank -%}
        <div class="al-col-hero__desc">{{ col.description }}</div>
      {%- endif -%}
      <p class="al-col-hero__count">
        {{ col.products_count }}
        {%- if col.products_count == 1 -%} product{%- else -%} products{%- endif -%}
      </p>
    </header>

    {%- comment %} ── PRODUCT GRID ── {%- endcomment %}
    {%- if col.products.size > 0 -%}
    <ul class="al-col-grid" role="list">
      {%- for product in col.products -%}
        {%- assign featured = product.featured_image -%}
        {%- assign first_variant = product.first_available_variant -%}
        <li class="al-col-grid__item">
          <div class="al-col-card" data-product-id="{{ product.id }}">

            {%- comment %} Card image {%- endcomment %}
            <a href="{{ product.url }}" class="al-col-card__img-wrap" tabindex="-1" aria-hidden="true">
              {%- if featured -%}
                {{
                  featured
                  | image_url: width: 600
                  | image_tag:
                    class: 'al-col-card__img',
                    widths: '300, 450, 600',
                    sizes: '(max-width: 767px) 44vw, 30vw',
                    loading: 'lazy',
                    alt: featured.alt | default: product.title
                }}
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'al-col-card__img al-col-card__img--placeholder' }}
              {%- endif -%}
            </a>

            {%- comment %} Badges {%- endcomment %}
            {%- if product.compare_at_price > product.price -%}
              {%- assign savings_pct = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
              <span class="al-col-card__badge al-col-card__badge--sale">–{{ savings_pct }}%</span>
            {%- endif -%}

            {%- comment %} Card body {%- endcomment %}
            <div class="al-col-card__body">
              <a href="{{ product.url }}" class="al-col-card__title">{{ product.title }}</a>

              <div class="al-col-card__price-row">
                <span class="al-col-card__price">{{ product.price | money }}</span>
                {%- if product.compare_at_price > product.price -%}
                  <span class="al-col-card__compare">{{ product.compare_at_price | money }}</span>
                {%- endif -%}
              </div>

              {%- comment %} Quick add (single-variant or first variant) {%- endcomment %}
              {%- if first_variant -%}
              <form
                action="/cart/add"
                method="post"
                class="al-col-card__quick-add-form"
                data-quick-add
              >
                <input type="hidden" name="id" value="{{ first_variant.id }}">
                <input type="hidden" name="quantity" value="1">
                <button
                  type="submit"
                  class="al-btn al-btn--primary al-btn--sm al-col-card__quick-add-btn"
                  {%- unless first_variant.available %} disabled aria-disabled="true"{% endunless %}
                >
                  {%- if first_variant.available -%}
                    Add to Cart
                  {%- else -%}
                    Sold Out
                  {%- endif -%}
                </button>
              </form>
              {%- endif -%}
            </div>
          </div>
        </li>
      {%- endfor -%}
    </ul>
    {%- else -%}
      <p class="al-col-hero__empty">No products found in this collection.</p>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "AutoLinkr Collection Hero",
  "tag": "section",
  "class": "section-autolinkr-collection-hero",
  "settings": [],
  "presets": [
    {
      "name": "AutoLinkr Collection Hero"
    }
  ]
}
{% endschema %}
