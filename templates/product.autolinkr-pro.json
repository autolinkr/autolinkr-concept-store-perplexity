        "collapsible-description": {
          "type": "collapsible_tab",
          "settings": {
            "opened": false,
            "style": "with-border",
            "icon": "none",
            "heading": "Description",
            "content": "<p>AutoLinkr Pro™ transforms any compatible car into a wireless entertainment hub. No more fumbling with cables every drive, no more watching your passengers stare at their phones on road trips.</p><p>Just plug it into your USB port once, pair your phone, and you're done — wireless CarPlay or Android Auto activates automatically every time you start your car.</p><p>With the built-in Google Play Store, you get Netflix, YouTube, Disney+, Hulu, and thousands of apps right on your car's factory screen.</p><p>Whether it's hands-free navigation on your commute or streaming movies for your kids on a road trip, AutoLinkr Pro™ is the single upgrade that makes your car feel brand new — in about a minute.</p>",
            "page": "",
            "liquid": "",
            "text_size": "text-sm"
          }
        },
        "collapsible-compatibility": {
          "type": "collapsible_tab",
          "settings": {
            "opened": false,
            "style": "with-border",
            "icon": "none",
            "heading": "Compatibility",
            "content": "<p>Works with any 2016+ vehicle with factory Apple CarPlay or Android Auto.</p><p>Compatible with 500+ models from Toyota, Honda, Ford, Chevrolet, BMW, Mercedes, Hyundai, Kia, Nissan, Subaru, Mazda, Volkswagen, Audi, and 30+ more manufacturers.</p><p>Not compatible with: Tesla, Rivian, Lucid, NIO.</p><p><a href=\"/pages/supported-cars\">Check Your Car →</a></p><p>Not sure? Contact us and we'll confirm in minutes.</p>",
            "page": "",
            "liquid": "",
            "text_size": "text-sm"
          }
        },
        "collapsible-specs": {
          "type": "collapsible_tab",
          "settings": {
            "opened": false,
            "style": "with-border",
            "icon": "none",
            "heading": "Tech Specs",
            "content": "<ul><li>Connectivity: Wireless CarPlay + Android Auto</li><li>Streaming: Netflix, YouTube, Disney+, Hulu, Prime Video + more</li><li>App Store: Full Google Play Store access</li><li>Setup: Plug-and-play, under 60 seconds</li><li>Connection: Bluetooth 5.0 + WiFi</li><li>Internet: Via phone hotspot or vehicle WiFi</li><li>Cables Included: USB-C to USB-A + USB-C to USB-C</li><li>Firmware: OTA (over-the-air) updates</li><li>Compatibility: 500+ vehicle models (2016+)</li><li>RAM: 2GB</li><li>Storage: 16GB built-in + Micro SD expandable</li></ul>",
            "page": "",
            "liquid": "",
            "text_size": "text-sm"
          }
        },
        "collapsible-shipping": {
          "type": "collapsible_tab",
          "settings": {
            "opened": false,
            "style": "with-border",
            "icon": "none",
            "heading": "Shipping & Returns",
            "content": "<p>FREE standard shipping on all orders (6-10 business days). Most orders placed before 2pm ET ship the same day.</p><p>30-day money-back guarantee — if AutoLinkr doesn't work with your car or you're not satisfied, return it for full in-store credit. We cover return shipping.</p><p>Lifetime customer support: support@theautolinkr.com</p>",
            "page": "",
            "liquid": "",
            "text_size": "text-sm"
          }
        },
        "text-safety": {
          "type": "text",
          "settings": {
            "icon": "none",
            "iwidth": "custom",
            "icon_width": 24,
            "text": "⚠️ Always operate your vehicle safely and in compliance with all applicable traffic and distracted-driving laws. Video playback is intended for passengers or when the vehicle is parked. The driver is solely responsible for safe and lawful vehicle operation at all times.",
            "text_size": "text-xs"
