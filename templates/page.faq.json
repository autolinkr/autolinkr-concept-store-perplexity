        "oq1": {
          "type": "question",
          "settings": {
            "title": "How fast will I receive my order?",
            "text": "<p>Orders ship within 1–2 business days. Most US customers receive their order within 3–5 business days after shipping. Expedited shipping options are available at checkout if you need it faster.</p>"
          }
        },
        "oq2": {
          "type": "question",
          "settings": {
            "title": "Is shipping really free?",
            "text": "<p>Yes — free shipping on every order, every time. No minimum order required. We cover the full shipping cost so there are no surprises at checkout.</p>"
          }
        },
        "oq3": {
          "type": "question",
          "settings": {
            "title": "What is your return policy?",
            "text": "<p>We offer a <strong>30-day money-back guarantee</strong> on all products. If you're not 100% satisfied for any reason, contact our support team within 30 days of delivery and we'll process a full refund — no questions asked.</p><p>You don't need to explain why. We'll make it right.</p>"
          }
        },
        "oq4": {
          "type": "question",
          "settings": {
            "title": "Does AutoLinkr offer a warranty?",
            "text": "<p>Yes — all AutoLinkr products come with a <strong>1-year limited warranty</strong> covering manufacturing defects. If your product develops a defect within 12 months of purchase, we'll replace it free of charge.</p><p>Warranty does not cover physical damage, water damage, or misuse.</p>"
          }
        },
        "oq5": {
          "type": "question",
          "settings": {
            "title": "Do you ship internationally?",
            "text": "<p>Currently, we ship to the United States and Canada. International shipping options may be available depending on your location — check the checkout for available shipping zones.</p>"
          }
        },
        "oq6": {
          "type": "question",
          "settings": {
            "title": "Can I track my order?",
            "text": "<p>Yes — once your order ships, you'll receive a tracking confirmation email with a link to follow your package in real time. You can also track your order directly through the carrier's website using the tracking number provided.</p>"
          }
        }
      },
