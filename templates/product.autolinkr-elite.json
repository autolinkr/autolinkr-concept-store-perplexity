      "blocks": {
        "t1": {
          "type": "testimonial",
          "settings": {
            "text": "<p>\"I had the Pro for a week and immediately upgraded to Elite when I found out about split-screen. Running Google Maps and Netflix at the same time while my wife navigates is next level.\"</p>",
            "author": "Derek M.",
            "author_info": "2023 BMW X5 \u2014 Verified Buyer"
          }
        },
        "t2": {
          "type": "testimonial",
          "settings": {
            "text": "<p>\"The Elite is genuinely the last thing I'll ever need for my car's display. Split-screen works flawlessly. My factory BMW screen went from outdated to incredible.\"</p>",
            "author": "Priya L.",
            "author_info": "2022 BMW 5-Series \u2014 Verified Buyer"
          }
        },
        "t3": {
          "type": "testimonial",
          "settings": {
            "text": "<p>\"Bought Elite after reading the comparison. The faster CPU is noticeable \u2014 zero lag switching between apps. Netflix and Waze running side-by-side is wild.\"</p>",
